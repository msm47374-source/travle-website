---
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import FAQSchema from '@/components/schema/FAQSchema.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import Breadcrumbs from '@/components/site/Breadcrumbs.astro';
import CTASection from '@/components/site/CTASection.astro';
import FAQAccordion from '@/components/site/FAQAccordion.astro';
import LocationCard from '@/components/site/LocationCard.astro';
import PageHero from '@/components/site/PageHero.astro';
import ServiceCard from '@/components/site/ServiceCard.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { blogPosts, getBlogPostBySlug } from '@/data/blog';
import { getLocationBySlug } from '@/data/locations';
import { getServiceBySlug } from '@/data/services';
import type { LocationRecord, ServiceRecord } from '@/data/types';
import { metaTitle } from '@/lib/seo';
import { formatDate } from '@/lib/utils';

export function getStaticPaths() {
  return blogPosts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const post = getBlogPostBySlug(Astro.params.slug ?? '');

if (!post) {
  throw new Error('Blog post not found');
}

const relatedServices = post.relatedServices
  .map((slug) => getServiceBySlug(slug))
  .filter((service): service is ServiceRecord => Boolean(service));
const relatedLocations = post.relatedLocations
  .map((slug) => getLocationBySlug(slug))
  .filter((location): location is LocationRecord => Boolean(location));
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog' },
  { name: post.title, path: `/blog/${post.slug}` },
];
const dateMeta = `${formatDate(post.publishedAt)} · ${post.readTime}`;
---

<BaseLayout
  title={metaTitle(post.title)}
  description={post.metaDescription}
  path={`/blog/${post.slug}`}
  ogType="article"
>
  <Fragment slot="schema">
    <LocalBusinessSchema />
    <FAQSchema items={post.faqs} />
    <BreadcrumbSchema items={breadcrumbs} />
  </Fragment>

  <PageHero
    eyebrow="Darwin cleaning guide"
    title={post.heroHeading}
    body={post.excerpt}
    backgroundImage={post.image.src}
    primaryLabel="Get a Free Quote"
    primaryHref="/contact"
    secondaryLabel="More articles"
    secondaryHref="/blog"
  />

  <Section>
    <Breadcrumbs items={breadcrumbs} />
    <div class="surface-card p-8">
      <p class="text-sm text-slate-500">{dateMeta}</p>
      <div class="rich-text mt-6 space-y-8">
        {post.sections.map((section) => (
          <section>
            <h2 class="text-3xl font-semibold">{section.heading}</h2>
            <div class="mt-4 space-y-4">
              {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </section>
        ))}
      </div>
    </div>
  </Section>

  <Section eyebrow="FAQs" title="Related questions" tone="alt">
    <FAQAccordion items={post.faqs} />
  </Section>

  <Section eyebrow="Related services" title="Useful service pages">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {relatedServices.map((service) => <ServiceCard service={service} />)}
    </div>
  </Section>

  <Section eyebrow="Related locations" title="Relevant Darwin locations">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {relatedLocations.map((location) => <LocationCard location={location} />)}
    </div>
  </Section>

  <CTASection
    title="Need help turning advice into a practical cleaning plan?"
    body="Tell us what property you are working with, the location, and the cleaning issue you want solved. We will point you toward the right service page or quote path."
  />
</BaseLayout>
