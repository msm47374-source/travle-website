---
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import CTASection from '@/components/site/CTASection.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import Breadcrumbs from '@/components/site/Breadcrumbs.astro';
import PageHero from '@/components/site/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { blogPosts } from '@/data/blog';
import { formatDate } from '@/lib/utils';

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Blog', path: '/blog' },
];
---

<BaseLayout
  title="Cleaning Blog Darwin | Cleaning Company Darwin"
  description="Read Darwin cleaning guides, seasonal advice, and service explainers for homes, offices, and specialist cleaning needs."
  path="/blog"
>
  <Fragment slot="schema">
    <LocalBusinessSchema />
    <BreadcrumbSchema items={breadcrumbs} />
  </Fragment>

  <PageHero
    eyebrow="Blog"
    title="Cleaning guides for Darwin homes, facilities, and property managers"
    body="The blog supports the service pages with more depth around wet-season residue, build-up humidity, move-out standards, and commercial cleaning planning in Darwin."
    backgroundImage={blogPosts[0]?.image.src ?? '/images/services/service-office-cleaning-01.jpg'}
    secondaryLabel="View Services"
    secondaryHref="/services"
  />

  <Section>
    <Breadcrumbs items={breadcrumbs} />
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {blogPosts.map((post) => {
        const dateMeta = `${formatDate(post.publishedAt)} · ${post.readTime}`;

        return (
          <article class="surface-card flex h-full flex-col overflow-hidden">
            <img src={post.image.src} alt={post.image.alt} width={post.image.width} height={post.image.height} class="border-b border-slate-200" />
            <div class="flex h-full flex-col p-6">
              <p class="text-sm text-slate-500">{dateMeta}</p>
              <h2 class="mt-3 text-2xl font-semibold">{post.title}</h2>
              <p class="mt-3">{post.excerpt}</p>
              <a href={`/blog/${post.slug}`} class="mt-6 text-sm font-semibold text-blue-700">Read article</a>
            </div>
          </article>
        );
      })}
    </div>
  </Section>

  <CTASection
    title="Need more than advice from a Darwin cleaning article?"
    body="Send us the property type, location, and the cleaning problem you want solved, and we will point you to the right service or booking path."
    primaryHref="/contact"
    secondaryHref="/services"
    secondaryLabel="Explore Services"
  />
</BaseLayout>
