---
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import FAQSchema from '@/components/schema/FAQSchema.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import ServiceSchema from '@/components/schema/ServiceSchema.astro';
import Breadcrumbs from '@/components/site/Breadcrumbs.astro';
import CTASection from '@/components/site/CTASection.astro';
import FAQAccordion from '@/components/site/FAQAccordion.astro';
import PageHero from '@/components/site/PageHero.astro';
import ServiceCard from '@/components/site/ServiceCard.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getServicePageContent } from '@/data/page-content';
import { getRelatedServices, getServiceBySlug, services } from '@/data/services';
import { metaTitle } from '@/lib/seo';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { service: service.slug },
  }));
}

const service = getServiceBySlug(Astro.params.service ?? '');

if (!service) {
  throw new Error('Service not found');
}

const relatedServices = getRelatedServices(service, 4);
const servicePage = getServicePageContent(service);
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Services', path: '/services' },
  { name: service.name, path: `/services/${service.slug}` },
];
---

<BaseLayout
  title={metaTitle(`${service.name} Darwin | Cleaning Company Darwin`)}
  description={service.metaDescription}
  path={`/services/${service.slug}`}
>
  <Fragment slot="schema">
    <LocalBusinessSchema />
    <ServiceSchema name={service.name} description={service.metaDescription} path={`/services/${service.slug}`} />
    <FAQSchema items={servicePage.faqs} />
    <BreadcrumbSchema items={breadcrumbs} />
  </Fragment>

  <PageHero
    eyebrow={service.category}
    title={service.heroHeading}
    body={service.intro}
    backgroundImage={service.image.src}
    primaryLabel={service.cta}
    primaryHref="/contact"
    secondaryLabel="View Service Areas"
    secondaryHref="/areas"
  />

  <Section>
    <Breadcrumbs items={breadcrumbs} />
    <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="surface-card p-8">
        <h2 class="text-3xl font-semibold">Why Darwin clients book this service</h2>
        <div class="mt-4 space-y-4 text-slate-700">
          <p>{service.description}</p>
          {servicePage.introParagraphs.map((paragraph) => <p set:html={paragraph}></p>)}
        </div>
      </div>
      <div class="surface-card p-8">
        <h2 class="text-3xl font-semibold">What the scope covers</h2>
        <ul class="mt-6 list-disc space-y-3 pl-5">
          {service.features.map((feature) => <li>{feature}</li>)}
        </ul>
        <h3 class="mt-8 text-xl font-semibold">Common issues we solve</h3>
        <ul class="mt-4 list-disc space-y-3 pl-5">
          {service.commonIssues.map((issue) => <li>{issue}</li>)}
        </ul>
        <p class="mt-6 rounded-[1rem] bg-blue-50 p-4 text-sm text-blue-900">{service.priceRange}</p>
      </div>
    </div>
  </Section>

  <CTASection
    title={servicePage.midCta.title}
    body={servicePage.midCta.body}
    primaryHref={servicePage.midCta.primaryHref}
    primaryLabel={servicePage.midCta.primaryLabel}
    secondaryHref={servicePage.midCta.secondaryHref}
    secondaryLabel={servicePage.midCta.secondaryLabel}
  />

  <Section eyebrow="Methodology" title={`How we approach ${service.name.toLowerCase()} in Darwin`} tone="alt">
    <div class="grid gap-6 lg:grid-cols-3">
      {servicePage.methodology.map((section) => (
        <div class="surface-card p-8">
          <h2 class="text-2xl font-semibold">{section.title}</h2>
          <div class="mt-4 space-y-4 text-slate-700">
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Process" title={`How ${service.name.toLowerCase()} is delivered`} tone="alt">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {servicePage.process.map((step, index) => (
        <div class="surface-card p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">Step {index + 1}</p>
          <h2 class="mt-4 text-2xl font-semibold">{step.title}</h2>
          <p class="mt-3">{step.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Local Knowledge" title={`Darwin advice for ${service.name.toLowerCase()}`}>
    <div class="surface-card p-8">
      <div class="space-y-4 text-slate-700">
        {servicePage.localKnowledge.map((paragraph) => <p set:html={paragraph}></p>)}
      </div>
    </div>
  </Section>

  <Section eyebrow="Seasonal Planning" title={`Seasonal considerations for ${service.name.toLowerCase()}`} tone="alt">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {servicePage.seasonalCards.map((card) => (
        <div class="surface-card p-6">
          <h2 class="text-2xl font-semibold">{card.title}</h2>
          <p class="mt-4 text-slate-700">{card.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Common Problems" title="Problems homeowners and property managers ask us to solve">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {servicePage.problemCards.map((card) => (
        <div class="surface-card p-6">
          <h2 class="text-2xl font-semibold">{card.title}</h2>
          <p class="mt-4 text-slate-700">{card.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Area Variants" title={`${service.name} pages for Darwin neighborhoods`} intro="Each page below is a dedicated service-and-location page, so users can move directly into neighborhood-level guidance instead of reading the same generic city copy everywhere.">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {servicePage.locationLinks.map((item) => (
        <a href={item.href} class="surface-card block p-6 transition hover:border-blue-300">
          <h2 class="text-xl font-semibold text-slate-900">{item.label}</h2>
          <p class="mt-3 text-sm text-slate-600">{item.description}</p>
        </a>
      ))}
    </div>
  </Section>

  <Section eyebrow="FAQs" title={`Questions about ${service.name.toLowerCase()}`} tone="alt">
    <FAQAccordion items={servicePage.faqs} />
  </Section>

  <Section eyebrow="Related services" title="Explore related cleaning solutions">
    <p class="max-w-3xl text-slate-600">{servicePage.relatedServicesIntro}</p>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {relatedServices.map((item) => <ServiceCard service={item} />)}
    </div>
  </Section>

  <Section eyebrow="We Also Serve" title="Nearby Darwin area pages">
    <p class="max-w-3xl text-slate-600">{servicePage.weAlsoServeIntro}</p>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {servicePage.areaLinks.map((item) => (
        <a href={item.href} class="surface-card block p-6 transition hover:border-blue-300">
          <h2 class="text-xl font-semibold text-slate-900">{item.label}</h2>
          <p class="mt-3 text-sm text-slate-600">{item.description}</p>
        </a>
      ))}
    </div>
  </Section>

  <CTASection
    title={servicePage.bottomCta.title}
    body={servicePage.bottomCta.body}
    primaryHref={servicePage.bottomCta.primaryHref}
    primaryLabel={servicePage.bottomCta.primaryLabel}
    secondaryHref={servicePage.bottomCta.secondaryHref}
    secondaryLabel={servicePage.bottomCta.secondaryLabel}
  />
</BaseLayout>
