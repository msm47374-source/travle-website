---
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import CTASection from '@/components/site/CTASection.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import FAQSchema from '@/components/schema/FAQSchema.astro';
import Breadcrumbs from '@/components/site/Breadcrumbs.astro';
import FAQAccordion from '@/components/site/FAQAccordion.astro';
import PageHero from '@/components/site/PageHero.astro';
import ServiceCard from '@/components/site/ServiceCard.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getServicesByCategory, serviceCategories } from '@/data/services';

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Services', path: '/services' },
];
const servicesFaqs = [
  { question: 'Do I need to supply cleaning equipment or products?', answer: 'No. We provide the necessary equipment and cleaning products for every agreed scope. If you have specific chemical sensitivities or want lower-odor products, mention that during booking.' },
  { question: 'What is the most popular cleaning service in Darwin?', answer: 'Our most frequently requested services are end-of-lease cleaning, deep residential cleans, recurring house cleaning, and commercial office maintenance, especially after wet-season residue or during build-up reset season.' },
  { question: 'Can I customise a cleaning service to fit my budget?', answer: 'Absolutely. We do not force you into rigid packages. You can specify areas of priority (e.g., focus on bathrooms and kitchen only) or exclude certain rooms to keep the scope within your preferred budget.' },
  { question: 'What happens if I am not satisfied with the cleaning?', answer: 'We stand by our work. If any part of the agreed scope is missed or not up to standard, contact us within 24 hours (or 72 hours for bond-back guarantees) and we will return to rectify the issue at no extra cost.' },
  { question: 'Do you clean properties that have been vacant for a long time?', answer: 'Yes. We handle pre-sale and post-vacancy deep cleans, addressing accumulated dust, pests, and stale environments to make the property presentation-ready.' },
];
---

<BaseLayout
  title="Cleaning Company Darwin Services"
  description="Browse all Darwin cleaning company services, including home, commercial, specialist, hygiene, and emergency cleaning."
  path="/services"
>
  <Fragment slot="schema">
    <LocalBusinessSchema />
    <BreadcrumbSchema items={breadcrumbs} />
    <FAQSchema items={servicesFaqs} />
  </Fragment>

  <PageHero
    eyebrow="Services"
    title="Cleaning company solutions built around real Darwin property needs"
    body="The site covers 146 individual service pages so users can find detailed content for residential cleaning, commercial programs, technical surface care, hygiene servicing, exterior work, and sensitive response cleaning."
    backgroundImage="/images/services/service-office-cleaning-01.jpg"
    secondaryLabel="Browse Areas"
    secondaryHref="/areas"
  />

  <Section>
    <Breadcrumbs items={breadcrumbs} />
    <div class="space-y-16">
      {serviceCategories.map((category) => (
        <div id={category.toLowerCase().replace(/[^a-z0-9]+/g, '-')} class="space-y-6">
          <h2 class="text-3xl font-semibold">{category}</h2>
          <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
            {getServicesByCategory(category).map((service) => <ServiceCard service={service} />)}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Service FAQs" title="Questions about our cleaning scopes" intro="Answers to common questions regarding service inclusion and coverage." tone="alt">
    <FAQAccordion items={servicesFaqs} />
  </Section>

  <CTASection
    title="Need help choosing the right cleaning company service?"
    body="Tell us the property type, location, and the result you need, and we will point you to the right service page or quote path."
    primaryHref="/contact"
    secondaryHref="/areas"
    secondaryLabel="Browse Service Areas"
  />
</BaseLayout>
