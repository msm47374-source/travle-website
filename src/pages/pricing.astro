---
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import FAQSchema from '@/components/schema/FAQSchema.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import Breadcrumbs from '@/components/site/Breadcrumbs.astro';
import FAQAccordion from '@/components/site/FAQAccordion.astro';
import PageHero from '@/components/site/PageHero.astro';
import Button from '@/components/ui/Button.astro';
import Icon from '@/components/ui/Icon.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getServiceBySlug, getServicesByCategory, serviceCategories } from '@/data/services';
import { site } from '@/data/site';

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Pricing', path: '/pricing' },
];

function requiredService(slug: string) {
  const service = getServiceBySlug(slug);

  if (!service) {
    throw new Error(`Pricing service missing: ${slug}`);
  }

  return service;
}

function pricingHeadline(priceRange: string) {
  const startingMatch = priceRange.match(/From \$[\d,]+/i);

  if (startingMatch) {
    return startingMatch[0].replace(/^From\s*/i, '');
  }

  if (/program/i.test(priceRange)) {
    return 'Program Quote';
  }

  if (/custom/i.test(priceRange) || /quoted/i.test(priceRange)) {
    return 'Custom Quote';
  }

  return 'Tailored Quote';
}

function categoryId(label: string) {
  return label.toLowerCase().replace(/[^a-z0-9]+/g, '-');
}

const featuredPricing = [
  {
    slug: 'regular-routine-house-cleaning',
    label: 'Home Essentials',
    accent: 'blue',
    summary: 'Recurring upkeep for apartments, family homes, and occupied townhomes.',
    bullets: ['Kitchens, bathrooms, dusting, floors', 'Best for weekly or fortnightly visits'],
  },
  {
    slug: 'deep-cleaning',
    label: 'Deep Reset',
    accent: 'green',
    summary: 'For catch-up cleans, seasonal resets, and homes that need more than a tidy-up.',
    bullets: ['Higher detail level and longer time on site', 'Popular after winter and before hosting'],
  },
  {
    slug: 'end-of-lease-bond-cleaning',
    label: 'Move-Out Ready',
    accent: 'amber',
    summary: 'Inspection-focused cleaning for rentals, vacates, and handover pressure.',
    bullets: ['Kitchens, bathrooms, tracks, skirtings', 'Add-ons available for ovens, carpets, and glass'],
  },
  {
    slug: 'carpet-steam-cleaning',
    label: 'Surface Refresh',
    accent: 'slate',
    summary: 'Popular add-on or standalone pricing for bedrooms, living rooms, and traffic lanes.',
    bullets: ['Works well with deep cleans and move-outs', 'Quoted by condition, stains, and area size'],
  },
].map((entry) => ({
  ...entry,
  service: requiredService(entry.slug),
}));

const pricingBands = [
  {
    title: 'Residential cleaning',
    service: requiredService('regular-routine-house-cleaning'),
    note: 'Recurring and one-off home cleaning for apartments, houses, townhomes, and occupied properties.',
  },
  {
    title: 'Deep and move-out cleaning',
    service: requiredService('end-of-lease-bond-cleaning'),
    note: 'The right range for high-detail resets, vacates, inspections, and presentation-sensitive jobs.',
  },
  {
    title: 'Carpet and floor care',
    service: requiredService('carpet-steam-cleaning'),
    note: 'Surface pricing depends on fibre type, stains, drying needs, and the amount of treated area.',
  },
  {
    title: 'Exterior washing',
    service: requiredService('pressure-high-pressure-washing'),
    note: 'Driveways, facades, patios, and exterior surfaces are priced by access, drainage, and surface area.',
  },
  {
    title: 'Commercial programs',
    service: requiredService('office-cleaning'),
    note: 'Offices and managed facilities are quoted around frequency, access hours, compliance, and site size.',
  },
  {
    title: 'Restoration and high-risk work',
    service: requiredService('emergency-response-cleaning-24-7'),
    note: 'Emergency, restoration, and sensitive cleanup work is assessed after urgency and containment needs are confirmed.',
  },
];

const specialistPrograms = [
  {
    title: 'Office and facility programs',
    service: requiredService('office-cleaning'),
    body: 'Best when you need nightly, weekly, or custom-frequency cleaning with access windows, reporting, and a repeatable scope.',
  },
  {
    title: 'Washroom and hygiene servicing',
    service: requiredService('washroom-servicing-and-hygiene-supply'),
    body: 'Quoted around room count, service interval, and consumables. Suitable for commercial and high-traffic facilities.',
  },
  {
    title: 'Emergency and restoration response',
    service: requiredService('emergency-response-cleaning-24-7'),
    body: 'Used when timing, equipment, remediation steps, or containment requirements make a fixed menu price unrealistic.',
  },
];

const pricingDirectoryGroups = serviceCategories.map((category) => ({
  category,
  id: categoryId(category),
  services: getServicesByCategory(category),
}));

const allServicesCount = pricingDirectoryGroups.reduce((total, group) => total + group.services.length, 0);

const quoteFactors = [
  {
    icon: 'clipboard',
    title: 'Size and scope',
    body: 'Room count, floor area, wet areas, and whether the visit is maintenance or corrective work all change time on site.',
  },
  {
    icon: 'sparkles',
    title: 'Condition of the property',
    body: 'Built-up grease, heavy dust, pet hair, stains, hard-water spotting, and neglected detail work increase labour and equipment needs.',
  },
  {
    icon: 'building',
    title: 'Access and logistics',
    body: 'Parking, elevators, managed buildings, after-hours entry, and tighter inspection windows can all affect the final quote.',
  },
  {
    icon: 'check-circle',
    title: 'Add-ons and specialist tools',
    body: 'Carpets, ovens, windows, pressure washing, extraction, or remediation add-ons are priced separately so the scope stays transparent.',
  },
];

const pricingFaqs = [
  {
    question: 'Are these fixed prices or starting rates?',
    answer:
      'They are guide prices. Where a service can be priced from a realistic baseline, we show that. When access, site condition, compliance, or risk changes the job materially, we quote after review instead of pretending one flat number fits every property.',
  },
  {
    question: 'Do you charge extra travel fees in Darwin?',
    answer:
      'Most Darwin suburbs and nearby service areas covered on the site are quoted without a separate travel line item. If a job sits on the outer edge of the service area or has unusual access requirements, we flag that before booking.',
  },
  {
    question: 'Are cleaning products and equipment included in the price?',
    answer:
      'Yes. Standard equipment and products required for the agreed scope are included. If the service needs specialist extraction, commercial equipment, PPE, or extra consumables, that is explained during quoting.',
  },
  {
    question: 'Can I bundle services to get a better price?',
    answer:
      'Usually, yes. Bundling services such as deep cleaning with carpet care, oven cleaning, or window cleaning often improves efficiency and can reduce the total compared with scheduling them separately.',
  },
  {
    question: 'How are office and commercial contracts priced?',
    answer:
      'Commercial work is priced around frequency, access hours, compliance requirements, site size, and whether washroom consumables or periodic specialist tasks are included. That is why most commercial programs are quoted rather than published as one flat number.',
  },
  {
    question: 'Can I get a same-day estimate?',
    answer:
      'Yes. If you call or message with the property type, location, service needed, and timing window, we can usually give a fast estimate or tell you what extra detail is needed to lock the quote down.',
  },
];

const phoneHref = `tel:${site.phone}`;
---

<BaseLayout
  title="Cleaning Pricing Darwin | Cleaning Company Darwin"
  description="Explore residential, move-out, carpet, exterior, and commercial cleaning pricing for Darwin with clear starting rates and transparent quote guidance."
  path="/pricing"
>
  <Fragment slot="schema">
    <LocalBusinessSchema />
    <BreadcrumbSchema items={breadcrumbs} />
    <FAQSchema items={pricingFaqs} />
  </Fragment>

  <PageHero
    eyebrow="Pricing"
    title="Darwin cleaning pricing that starts clearly and stays honest when the scope changes"
    body="Compare the services people price most often, then move deeper into the exact service page if property condition, building access, timing windows, or add-ons are likely to affect the quote."
    backgroundImage="/images/branding/hero-home-darwin-cleaning-02.jpg"
    primaryLabel="Request a Detailed Quote"
    primaryHref="/contact"
  />

  <Section class="pt-8 md:pt-10">
    <div class="mb-8 md:mb-10">
      <Breadcrumbs items={breadcrumbs} />
    </div>

    <div class="pricing-overview">
      <div class="pricing-overview-copy surface-card">
        <p class="pricing-overview-kicker">How to use this page</p>
        <h2 class="pricing-overview-title">
          Compare published starting rates first, then switch to tailored quoting when the scope genuinely changes.
        </h2>
        <p class="pricing-overview-intro">
          Routine home cleaning, deep resets, move-out work, and carpet care are easy to compare from visible
          starting points. Commercial programs, hygiene servicing, and emergency scopes move to quoting once
          compliance, access, timing, or risk changes the labor plan.
        </p>
        <div class="pricing-quick-points">
          <div class="pricing-quick-point">
            <span class="pricing-quick-point-icon">
              <Icon name="check-circle" size={16} />
            </span>
            <div>
              <p class="pricing-quick-point-title">Common home jobs have visible starting rates</p>
              <p class="pricing-quick-point-body">Routine cleans, deep cleans, move-out work, and carpet care are easy to compare before you contact us.</p>
            </div>
          </div>
          <div class="pricing-quick-point">
            <span class="pricing-quick-point-icon">
              <Icon name="check-circle" size={16} />
            </span>
            <div>
              <p class="pricing-quick-point-title">Custom quote territory is clearly marked</p>
              <p class="pricing-quick-point-body">Office cleaning, hygiene programs, and emergency work move to quoting once scope and timing are confirmed.</p>
            </div>
          </div>
          <div class="pricing-quick-point">
            <span class="pricing-quick-point-icon">
              <Icon name="check-circle" size={16} />
            </span>
            <div>
              <p class="pricing-quick-point-title">Darwin conditions are priced in upfront</p>
              <p class="pricing-quick-point-body">Humidity, wet-season scheduling, coastal residue, and building access can all influence the final number.</p>
            </div>
          </div>
        </div>
        <p class="pricing-overview-links">
          Want the full picture? Browse the <a href="/services" class="pricing-hero-link">service pages</a> or
          compare neighborhood-specific access on the <a href="/areas" class="pricing-hero-link">Darwin area pages</a>.
        </p>
      </div>

      <div class="pricing-panel surface-card">
        <div class="pricing-panel-head">
          <div>
            <p class="pricing-panel-kicker">Most requested services</p>
            <h2 class="pricing-panel-title">Quick pricing guide</h2>
          </div>
          <p class="pricing-panel-copy">
            Start here, then open the matching service page if your job needs more detail.
          </p>
        </div>
        <div class="pricing-quick-grid">
          {featuredPricing.map((item) => (
            <a href={`/services/${item.service.slug}`} class={`pricing-quick-card pricing-quick-card--${item.accent}`}>
              <div class="pricing-quick-card-top">
                <p class="pricing-mini-label">{item.label}</p>
                <span class="pricing-quick-arrow">
                  <Icon name="arrow-right" size={14} />
                </span>
              </div>
              <p class="pricing-quick-figure">{pricingHeadline(item.service.priceRange)}</p>
              <h3 class="pricing-quick-service">{item.service.name}</h3>
              <p class="pricing-quick-summary">{item.summary}</p>
              <p class="pricing-quick-range">{item.service.priceRange}</p>
            </a>
          ))}
        </div>
        <div class="pricing-panel-footer">
          <p class="pricing-panel-footer-title">Need office, hygiene, or emergency work?</p>
          <p class="pricing-panel-footer-copy">
            Those services move to a custom quote once timing, compliance, access, or risk changes the scope.
          </p>
        </div>
      </div>
    </div>
  </Section>

  <Section eyebrow="Most booked" title="Starting rates for the services people price first" intro="These are guide prices, not bait numbers. If access, condition, or add-ons change the job, we explain that before booking.">
    <div class="grid gap-6 lg:grid-cols-2">
      {featuredPricing.map((item) => (
        <article class={`pricing-feature-card pricing-feature-card--${item.accent}`}>
          <div class="pricing-feature-top">
            <div>
              <p class="pricing-feature-label">{item.label}</p>
              <h2 class="mt-2 text-3xl font-semibold">{item.service.name}</h2>
            </div>
            <div class="pricing-feature-badge">{pricingHeadline(item.service.priceRange)}</div>
          </div>
          <p class="mt-5 text-slate-700">{item.summary}</p>
          <p class="mt-5 text-sm font-semibold text-slate-900">{item.service.priceRange}</p>
          <ul class="mt-5 space-y-3">
            {item.bullets.map((bullet) => (
              <li class="flex items-start gap-3 text-sm text-slate-700">
                <span class="mt-1 inline-flex h-6 w-6 items-center justify-center rounded-full bg-white/80 text-blue-700">
                  <Icon name="check-circle" size={14} />
                </span>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
          <div class="mt-6 flex flex-col gap-3 sm:flex-row">
            <Button href={`/services/${item.service.slug}`} variant="secondary" iconRight="arrow-right">View service details</Button>
            <Button href="/contact" variant="light" iconRight="arrow-right">Get a quote</Button>
          </div>
        </article>
      ))}
    </div>
  </Section>

  <Section tone="alt" eyebrow="Pricing by service type" title="How pricing behaves across the wider service mix" intro="Not every service should be forced into a flat price table. This breakdown shows where starting rates are useful and where tailored quoting is the honest approach.">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {pricingBands.map((band) => (
        <article class="surface-card h-full p-7">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">{band.title}</p>
          <p class="mt-4 text-3xl font-semibold text-slate-900">{pricingHeadline(band.service.priceRange)}</p>
          <p class="mt-3 text-sm font-semibold text-slate-900">{band.service.priceRange}</p>
          <p class="mt-4 text-slate-700">{band.note}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section eyebrow="Full pricing directory" title={`All ${allServicesCount} services with pricing guidance`} intro="This section mirrors the services page structure, so you can scan every category, compare pricing language, and jump directly into the exact service page you need.">
    <div class="pricing-directory-nav">
      {pricingDirectoryGroups.map((group) => (
        <a href={`#${group.id}`} class="pricing-directory-chip">
          <span>{group.category}</span>
          <span class="pricing-directory-chip-count">{group.services.length}</span>
        </a>
      ))}
    </div>

    <div class="pricing-directory-grid">
      {pricingDirectoryGroups.map((group) => (
        <article id={group.id} class="pricing-group-card">
          <div class="pricing-group-head">
            <div>
              <p class="pricing-group-count">{group.services.length} services</p>
              <h2 class="mt-2 text-3xl font-semibold">{group.category}</h2>
            </div>
            <a href={`/services#${group.id}`} class="pricing-group-link">View category page</a>
          </div>

          <div class="pricing-service-list">
            {group.services.map((service) => (
              <a href={`/services/${service.slug}`} class="pricing-service-row">
                <div class="pricing-service-copy">
                  <p class="pricing-service-name">{service.name}</p>
                  <p class="pricing-service-headline">{pricingHeadline(service.priceRange)}</p>
                </div>
                <div class="pricing-service-price">
                  <p class="pricing-service-range">{service.priceRange}</p>
                  <span class="pricing-service-arrow">
                    <Icon name="arrow-right" size={14} />
                  </span>
                </div>
              </a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </Section>

  <Section eyebrow="What changes price" title="Four things that move a quote up or down" intro="We would rather explain the quote clearly than hide the moving parts behind a generic range. These are the factors that matter most.">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {quoteFactors.map((factor) => (
        <article class="pricing-factor-card">
          <span class="pricing-factor-icon">
            <Icon name={factor.icon as 'clipboard' | 'sparkles' | 'building' | 'check-circle'} size={18} />
          </span>
          <h2 class="mt-5 text-2xl font-semibold">{factor.title}</h2>
          <p class="mt-4 text-slate-700">{factor.body}</p>
        </article>
      ))}
    </div>
  </Section>

  <Section tone="alt" eyebrow="Programs and specialist scopes" title="Where we quote after review" intro="Commercial, hygiene, and emergency services usually need a better scoping conversation before we can give you a number that is worth trusting.">
    <div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
      <div class="surface-card p-8">
        <h2 class="text-3xl font-semibold">Custom pricing is there to protect the result, not hide it</h2>
        <div class="mt-5 space-y-4 text-slate-700">
          <p>
            For services such as <a href="/services/office-cleaning" class="pricing-body-link">office cleaning</a>,
            <a href="/services/washroom-servicing-and-hygiene-supply" class="pricing-body-link"> washroom and hygiene servicing</a>,
            and <a href="/services/emergency-response-cleaning-24-7" class="pricing-body-link">emergency response cleaning</a>,
            the quote depends on timing, compliance, access windows, room count, and equipment requirements.
          </p>
          <p>
            Publishing one flat number for those jobs usually creates the wrong expectation. Instead, we explain the scope,
            show what is affecting the price, and confirm whether the work should be staged, bundled, or handled after hours.
          </p>
          <p>
            If you are comparing options for a home, a rental handover, or a managed building in Darwin, the fastest way to
            get a useful number is to send the property type, neighborhood, service needed, and any add-ons or timing limits.
          </p>
        </div>
      </div>

      <div class="space-y-6">
        {specialistPrograms.map((item) => (
          <article class="surface-card p-7">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">{item.title}</p>
            <p class="mt-4 text-3xl font-semibold text-slate-900">{pricingHeadline(item.service.priceRange)}</p>
            <p class="mt-3 text-sm font-semibold text-slate-900">{item.service.priceRange}</p>
            <p class="mt-4 text-slate-700">{item.body}</p>
          </article>
        ))}
      </div>
    </div>
  </Section>

  <Section eyebrow="FAQs" title="Pricing questions we hear most often" tone="alt">
    <FAQAccordion items={pricingFaqs} />
  </Section>

  <Section class="pt-6">
    <div class="pricing-closing-card">
      <div>
        <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-100">Ready to price your job properly?</p>
        <h2 class="mt-3 text-3xl font-semibold text-white md:text-4xl">Need a precise price, not a vague range?</h2>
        <p class="mt-4 max-w-2xl text-blue-100">
          Tell us the service, location, property type, and timing window, and we will come back with a clear next step.
        </p>
      </div>
      <div class="flex flex-col gap-3 sm:flex-row">
        <Button href="/contact" variant="light" iconRight="arrow-right">Request a Detailed Quote</Button>
        <Button href={phoneHref} variant="ghost-light" iconLeft="phone">Call Now - Free Estimate</Button>
      </div>
    </div>
  </Section>
</BaseLayout>

<style>
  .pricing-overview {
    display: grid;
    gap: 1.5rem;
    align-items: start;
  }

  .pricing-overview-copy {
    padding: 1.5rem;
    border-radius: 1.75rem;
    border: 1px solid rgba(148, 163, 184, 0.2);
    background:
      radial-gradient(circle at top left, rgba(219, 234, 254, 0.52), transparent 15rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.98));
    box-shadow: 0 24px 52px rgba(15, 23, 42, 0.08);
  }

  .pricing-overview-kicker {
    margin: 0;
    color: #1d4ed8;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .pricing-overview-title {
    margin-top: 0.65rem;
    max-width: 18ch;
    color: #0f172a;
    font-size: clamp(2rem, 4vw, 3.2rem);
    line-height: 1.05;
  }

  .pricing-overview-intro {
    margin-top: 1rem;
    max-width: 42rem;
    color: #475569;
    line-height: 1.75;
  }

  .pricing-hero-link {
    color: #1d4ed8;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  .pricing-body-link {
    color: #1d4ed8;
    font-weight: 600;
    text-decoration: underline;
    text-underline-offset: 0.22rem;
  }

  .pricing-quick-points {
    display: grid;
    gap: 0.85rem;
    margin-top: 1.5rem;
    width: 100%;
  }

  .pricing-quick-point {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.85rem;
    align-items: flex-start;
    padding: 1rem 1.05rem;
    border: 1px solid rgba(148, 163, 184, 0.24);
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.74);
    box-shadow: 0 14px 34px rgba(15, 23, 42, 0.05);
  }

  .pricing-quick-point-icon {
    display: inline-flex;
    width: 2.1rem;
    height: 2.1rem;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: rgba(219, 234, 254, 0.92);
    color: #1d4ed8;
    flex-shrink: 0;
  }

  .pricing-quick-point-title {
    margin: 0;
    color: #0f172a;
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.45;
  }

  .pricing-quick-point-body {
    margin: 0.35rem 0 0;
    color: #475569;
    font-size: 0.93rem;
    line-height: 1.6;
  }

  .pricing-overview-links {
    margin: 1.25rem 0 0;
    max-width: 40rem;
    color: #475569;
    font-size: 0.95rem;
    line-height: 1.65;
  }

  .pricing-panel {
    width: 100%;
    padding: 1.5rem;
    border-radius: 1.75rem;
    border: 1px solid rgba(148, 163, 184, 0.2);
    background:
      radial-gradient(circle at top right, rgba(191, 219, 254, 0.6), transparent 13rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.98));
    box-shadow: 0 28px 60px rgba(15, 23, 42, 0.1);
  }

  .pricing-panel-head {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 1.15rem;
  }

  .pricing-panel-kicker {
    margin: 0;
    color: #1d4ed8;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }

  .pricing-panel-title {
    margin-top: 0.6rem;
    color: #0f172a;
    font-size: clamp(1.65rem, 3vw, 2.3rem);
    line-height: 1.05;
  }

  .pricing-panel-copy {
    margin: 0;
    max-width: 34rem;
    color: #475569;
    line-height: 1.6;
  }

  .pricing-quick-grid {
    display: grid;
    gap: 1rem;
  }

  .pricing-quick-card {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 1.15rem;
    border-radius: 1.35rem;
    border: 1px solid rgba(148, 163, 184, 0.18);
    box-shadow: 0 18px 38px rgba(15, 23, 42, 0.08);
    color: inherit;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .pricing-quick-card:hover {
