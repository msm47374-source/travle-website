---
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import FAQSchema from '@/components/schema/FAQSchema.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import ServiceSchema from '@/components/schema/ServiceSchema.astro';
import Breadcrumbs from '@/components/site/Breadcrumbs.astro';
import CTASection from '@/components/site/CTASection.astro';
import FAQAccordion from '@/components/site/FAQAccordion.astro';
import MapEmbed from '@/components/site/MapEmbed.astro';
import PageHero from '@/components/site/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { combinations, getCombinationBySlugs } from '@/data/combinations';
import { getLocationBySlug } from '@/data/locations';
import { getCombinationPageContent } from '@/data/page-content';
import { getServiceBySlug } from '@/data/services';
import { metaTitle } from '@/lib/seo';

export function getStaticPaths() {
  return combinations.map((combination) => ({
    params: {
      location: combination.locationSlug,
      service: combination.serviceSlug,
    },
  }));
}

const combination = getCombinationBySlugs(Astro.params.location ?? '', Astro.params.service ?? '');

if (!combination) {
  throw new Error('Combination not found');
}

const service = getServiceBySlug(combination.serviceSlug);
const location = getLocationBySlug(combination.locationSlug);

if (!service || !location) {
  throw new Error('Combination data incomplete');
}

const combinationPage = getCombinationPageContent(service, location, combination);
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Areas', path: '/areas' },
  { name: location.name, path: `/areas/${location.slug}` },
  { name: service.name, path: `/areas/${location.slug}/${service.slug}` },
];
---

<BaseLayout
  title={metaTitle(`${service.name} ${location.name} | Cleaning Company Darwin`)}
  description={`Book ${service.name.toLowerCase()} in ${location.name}, Darwin with neighborhood-specific content, local FAQs, and clearer pricing context.`}
  path={`/areas/${location.slug}/${service.slug}`}
  showGlobalMap={false}
>
  <Fragment slot="schema">
    <LocalBusinessSchema />
    <ServiceSchema
      name={`${service.name} in ${location.name}`}
      description={combinationPage.heroBody}
      path={`/areas/${location.slug}/${service.slug}`}
      areaServed={location.name}
    />
    <FAQSchema items={combinationPage.faqs} />
    <BreadcrumbSchema items={breadcrumbs} />
  </Fragment>

  <PageHero
    eyebrow={`${service.category} in ${location.name}`}
    title={`${service.name} in ${location.name}, Darwin`}
    body={combinationPage.heroBody}
    backgroundImage={service.image.src}
    primaryLabel={service.cta}
    primaryHref="/contact"
    secondaryLabel={`About ${location.name}`}
    secondaryHref={`/areas/${location.slug}`}
  />

  <Section>
    <Breadcrumbs items={breadcrumbs} />
    <div class="grid gap-6 lg:grid-cols-[1.05fr_0.95fr]">
      <div class="surface-card p-8">
        <h2 class="text-3xl font-semibold">Why this local page is different</h2>
        <div class="mt-6 space-y-4 text-slate-700">
          {combinationPage.overviewParagraphs.map((paragraph) => <p set:html={paragraph}></p>)}
        </div>
      </div>
      <div class="surface-card p-8">
        <h2 class="text-3xl font-semibold">Pricing note for {location.name}</h2>
        <p class="mt-4 text-slate-700">{combination.pricingNote}</p>
        <ul class="mt-6 list-disc space-y-3 pl-5 text-slate-700">
          {combination.localProblems.map((problem) => <li>{problem}</li>)}
        </ul>
        <div class="mt-6 rounded-[1rem] bg-green-50 p-4 text-sm text-green-900">
          {combination.localTip}
        </div>
      </div>
    </div>
  </Section>

  <CTASection
    title={combinationPage.midCta.title}
    body={combinationPage.midCta.body}
    primaryHref={combinationPage.midCta.primaryHref}
    primaryLabel={combinationPage.midCta.primaryLabel}
    secondaryHref={combinationPage.midCta.secondaryHref}
    secondaryLabel={combinationPage.midCta.secondaryLabel}
  />

  <Section eyebrow="Methodology" title={`How ${service.name.toLowerCase()} is handled in ${location.name}`} tone="alt">
    <div class="grid gap-6 lg:grid-cols-3">
      {combinationPage.methodology.map((section) => (
        <div class="surface-card p-8">
          <h2 class="text-2xl font-semibold">{section.title}</h2>
          <div class="mt-4 space-y-4 text-slate-700">
            {section.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
          </div>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Process" title={`How ${service.name.toLowerCase()} works in ${location.name}`} tone="alt">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {combinationPage.process.map((step, index) => (
        <div class="surface-card p-6">
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">Step {index + 1}</p>
          <h2 class="mt-4 text-2xl font-semibold">{step.title}</h2>
          <p class="mt-3">{step.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Seasonal Planning" title={`Seasonal considerations in ${location.name}`}>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {combinationPage.seasonalCards.map((card) => (
        <div class="surface-card p-6">
          <h2 class="text-2xl font-semibold">{card.title}</h2>
          <p class="mt-4 text-slate-700">{card.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="Common Problems" title={`Problems we solve around ${location.name}`}>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {combinationPage.problemCards.map((card) => (
        <div class="surface-card p-6">
          <h2 class="text-2xl font-semibold">{card.title}</h2>
          <p class="mt-4 text-slate-700">{card.body}</p>
        </div>
      ))}
    </div>
  </Section>

  <Section eyebrow="FAQs" title={`${service.name} questions specific to ${location.name}`}>
    <FAQAccordion items={combinationPage.faqs} />
  </Section>

  <Section eyebrow="Related Services" title={`More cleaning solutions in ${location.name}`} tone="alt">
    <p class="max-w-3xl text-slate-600">{combinationPage.relatedServicesIntro}</p>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {combinationPage.relatedServices.map((item) => (
        <a href={item.href} class="surface-card block p-6 transition hover:border-blue-300">
          <h2 class="text-xl font-semibold text-slate-900">{item.label}</h2>
          <p class="mt-3 text-sm text-slate-600">{item.description}</p>
        </a>
      ))}
    </div>
  </Section>

  <Section eyebrow="We Also Serve" title="Nearby area pages">
    <p class="max-w-3xl text-slate-600">{combinationPage.weAlsoServeIntro}</p>
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {combinationPage.nearbyAreaLinks.map((item) => (
        <a href={item.href} class="surface-card block p-6 transition hover:border-blue-300">
          <h2 class="text-xl font-semibold text-slate-900">{item.label}</h2>
          <p class="mt-3 text-sm text-slate-600">{item.description}</p>
        </a>
      ))}
    </div>
  </Section>

  <MapEmbed
    heading={`Serving ${location.name}, Darwin and nearby neighborhoods`}
    body={`This ${service.name.toLowerCase()} page is tailored for ${location.name} and nearby Darwin neighborhoods that share similar access patterns and cleaning conditions.`}
  />

  <CTASection
    title={combinationPage.bottomCta.title}
    body={combinationPage.bottomCta.body}
    primaryHref={combinationPage.bottomCta.primaryHref}
    primaryLabel={combinationPage.bottomCta.primaryLabel}
    secondaryHref={combinationPage.bottomCta.secondaryHref}
    secondaryLabel={combinationPage.bottomCta.secondaryLabel}
  />
</BaseLayout>
