---
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import CTASection from '@/components/site/CTASection.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import FAQSchema from '@/components/schema/FAQSchema.astro';
import Breadcrumbs from '@/components/site/Breadcrumbs.astro';
import FAQAccordion from '@/components/site/FAQAccordion.astro';
import LocationCard from '@/components/site/LocationCard.astro';
import PageHero from '@/components/site/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { locations } from '@/data/locations';

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Areas', path: '/areas' },
];
const areasFaqs = [
  { question: 'Do you charge travel fees for certain Darwin suburbs?', answer: 'Most Darwin suburbs and nearby service locations on this site are covered without a separate travel charge. For outer-edge jobs or unusual access requirements, any extra travel or setup cost is quoted upfront before booking.' },
  { question: 'Which Darwin area books the most end-of-lease cleans?', answer: 'We see strong demand for end-of-lease cleans in rental-heavy areas such as Darwin City, Parap, Nightcliff, and Winnellie, where turnovers, inspections, and short move windows are common.' },
  { question: 'How do cleaning needs differ across Darwin locations?', answer: 'CBD and waterfront locations often require more access planning, while suburban areas bring more driveway grit, outdoor residue, and family-home floorplans. We adapt the service sequence to the local property style instead of assuming every Darwin area behaves the same way.' },
  { question: 'If my suburb is not listed, do you still service it?', answer: 'Most likely, yes. The locations listed are our primary local hubs, but we cover the broader Darwin service area as well. Send your postcode and property type to confirm availability.' },
  { question: 'Do you offer commercial cleaning in industrial or logistics areas?', answer: 'Yes. We provide commercial and industrial cleaning support in warehouse corridors, trade precincts, and mixed-use service areas around Darwin, including logistics-adjacent sites that need practical access planning.' },
];
---

<BaseLayout
  title="Darwin Service Areas | Cleaning Company Darwin"
  description="Browse Darwin cleaning company coverage locations across the CBD, northern suburbs, family areas, and nearby service corridors."
  path="/areas"
>
  <Fragment slot="schema">
    <LocalBusinessSchema />
    <BreadcrumbSchema items={breadcrumbs} />
    <FAQSchema items={areasFaqs} />
  </Fragment>

  <PageHero
    eyebrow="Service areas"
    title="Darwin locations covered by our cleaning company"
    body="Each location page includes ZIP-code context, nearby landmarks, local cleaning conditions, and direct links to every service available in that area."
    backgroundImage="/images/areas/team-on-site-darwin-03.jpg"
    secondaryLabel="View Services"
    secondaryHref="/services"
  />

  <Section>
    <Breadcrumbs items={breadcrumbs} />
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {locations.map((location) => <LocationCard location={location} />)}
    </div>
  </Section>

  <Section eyebrow="Location FAQs" title="Questions about Darwin service areas" intro="Details on our coverage area, travel, and local service differences." tone="alt">
    <FAQAccordion items={areasFaqs} />
  </Section>

  <CTASection
    title="Looking for a cleaning company at your Darwin location?"
    body="Choose your area or send us your location, property type, and timing window, and we will guide you to the right local page."
    primaryHref="/contact"
    secondaryHref="/services"
    secondaryLabel="View All Services"
  />
</BaseLayout>
