---
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import FAQSchema from '@/components/schema/FAQSchema.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import Breadcrumbs from '@/components/site/Breadcrumbs.astro';
import CTASection from '@/components/site/CTASection.astro';
import FAQAccordion from '@/components/site/FAQAccordion.astro';
import LocationCard from '@/components/site/LocationCard.astro';
import MapEmbed from '@/components/site/MapEmbed.astro';
import PageHero from '@/components/site/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getLocationBySlug, getNearbyLocations, locations } from '@/data/locations';
import { getServicesByCategory, serviceCategories } from '@/data/services';
import { metaTitle } from '@/lib/seo';

export function getStaticPaths() {
  return locations.map((location) => ({
    params: { location: location.slug },
  }));
}

const location = getLocationBySlug(Astro.params.location ?? '');

if (!location) {
  throw new Error('Location not found');
}

const nearbyLocations = getNearbyLocations(location, 4);
const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Areas', path: '/areas' },
  { name: location.name, path: `/areas/${location.slug}` },
];
---

<BaseLayout
  title={metaTitle(`Cleaning Company ${location.name} | Darwin`)}
  description={`Cleaning company support in ${location.name}, Darwin. Residential, commercial, specialist, and emergency cleaning with location-specific local detail.`}
  path={`/areas/${location.slug}`}
  showGlobalMap={false}
>
  <Fragment slot="schema">
    <LocalBusinessSchema />
    <FAQSchema items={location.faqs} />
    <BreadcrumbSchema items={breadcrumbs} />
  </Fragment>

  <PageHero
    eyebrow={location.region}
    title={`Cleaning Company in ${location.name}, Darwin`}
    body={location.intro}
    backgroundImage={location.image.src}
    primaryLabel="Request a quote"
    primaryHref="/contact"
    secondaryLabel="View all services"
    secondaryHref="/services"
  />

  <Section>
    <Breadcrumbs items={breadcrumbs} />
    <div class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="surface-card p-8">
        <h2 class="text-3xl font-semibold">What makes {location.name} different</h2>
        <p class="mt-4">{location.localInsight}</p>
        <div class="mt-6 grid gap-4 md:grid-cols-2">
          <div class="rounded-[1rem] bg-slate-50 p-4">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Postcodes</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">{location.zip.join(', ')}</p>
          </div>
          <div class="rounded-[1rem] bg-slate-50 p-4">
            <p class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">Nearby neighborhoods</p>
            <p class="mt-2 text-lg font-semibold text-slate-900">{location.neighborhoods.join(', ')}</p>
          </div>
        </div>
      </div>
      <div class="surface-card p-8">
        <h2 class="text-3xl font-semibold">Landmarks and local references</h2>
        <ul class="mt-6 space-y-4">
          {location.landmarks.map((landmark) => (
            <li class="rounded-[1rem] bg-slate-50 p-4">
              <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">{landmark.type}</p>
              <p class="mt-2 text-lg font-semibold text-slate-900">{landmark.name}</p>
              <p class="mt-2">{landmark.description}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </Section>

  <Section eyebrow="Available services" title={`Every service available in ${location.name}`} intro="This area page links to every service route available for this location so users can jump straight into the exact service-and-location page they need." tone="alt">
    <div class="space-y-8">
      {serviceCategories.map((category) => (
        <div class="surface-card p-8">
          <h2 class="text-2xl font-semibold">{category}</h2>
          <div class="mt-5 grid gap-3 md:grid-cols-2 xl:grid-cols-4">
            {getServicesByCategory(category).map((service) => (
              <a href={`/areas/${location.slug}/${service.slug}`} class="rounded-xl border border-slate-200 px-4 py-4 transition hover:border-blue-300 hover:text-slate-900">
                <p class="text-sm font-semibold text-slate-900">{service.name} in {location.name}</p>
                <p class="mt-2 text-xs font-semibold uppercase tracking-[0.18em] text-blue-700">Pricing guide</p>
                <p class="mt-2 text-sm text-slate-600">{service.priceRange}</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>
  </Section>


  <Section eyebrow="Location FAQs" title={`Questions about booking cleaning in ${location.name}`} tone="alt">
    <FAQAccordion items={location.faqs} />
  </Section>

  <Section eyebrow="Nearby areas" title="Explore nearby locations">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {nearbyLocations.map((item) => <LocationCard location={item} />)}
    </div>
  </Section>

  <MapEmbed
    heading={`Serving ${location.name}, Darwin and Surrounding Neighborhoods`}
    body={`Use this page as the local hub for ${location.name}. We support homes, commercial sites, and specialist cleaning scopes across nearby Darwin neighborhoods as well.`}
  />

  <CTASection
    title={`Need cleaning help in ${location.name}?`}
    body={`Tell us what property you manage in ${location.name}, which service you need, and when you want it completed. We will map out the right next step.`}
    secondaryHref="/contact"
    secondaryLabel="Contact Cleaning Company Darwin"
  />
</BaseLayout>
