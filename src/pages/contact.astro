---
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import CTASection from '@/components/site/CTASection.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import FAQSchema from '@/components/schema/FAQSchema.astro';
import Breadcrumbs from '@/components/site/Breadcrumbs.astro';
import ContactForm from '@/components/site/ContactForm.astro';
import FAQAccordion from '@/components/site/FAQAccordion.astro';
import MapEmbed from '@/components/site/MapEmbed.astro';
import PageHero from '@/components/site/PageHero.astro';
import Icon from '@/components/ui/Icon.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { locations } from '@/data/locations';
import { site } from '@/data/site';
import { services } from '@/data/services';

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'Contact', path: '/contact' },
];
const contactFaqs = [
  { question: 'How quickly will you respond to my enquiry?', answer: 'We aim to respond to all contact form submissions and calls within a few hours during business hours. For urgent or emergency cleaning requests, note the urgency in your message and we will prioritise the response.' },
  { question: 'What information should I include in my quote request?', answer: 'Include the property type (house, apartment, office, commercial), your suburb, the service you need, the preferred date or timeframe, and any access restrictions or special requirements. The more detail you provide, the faster we can give you an accurate quote.' },
  { question: 'Can I get a fixed price before the cleaner arrives?', answer: 'Yes. We provide clear scopes and fixed or indicative pricing before the job starts. We do not add surprise charges on arrival. If additional work is identified on-site, we discuss it with you before proceeding.' },
  { question: 'Do you offer emergency or same-day cleaning?', answer: 'Yes. We support emergency response cleaning for events like storm aftermath, sewage incidents, or urgent handovers. Include the urgency and site type in your message so we can triage it quickly.' },
  { question: 'How do I prepare for a cleaning visit?', answer: 'For most services, just ensure access to the property and clear any fragile or sensitive items. For specific services like carpet cleaning or high-pressure washing, we will advise on preparation in the booking confirmation.' },
];
---

<BaseLayout
  title="Contact Cleaning Company Darwin"
  description="Request a Darwin cleaning quote for residential, commercial, specialist, or emergency jobs. Contact Cleaning Company Darwin today."
  path="/contact"
  showGlobalMap={false}
>
  <Fragment slot="schema">
    <LocalBusinessSchema />
    <BreadcrumbSchema items={breadcrumbs} />
    <FAQSchema items={contactFaqs} />
  </Fragment>

  <PageHero
    eyebrow="Contact"
    title="Contact Cleaning Company Darwin"
    body="Tell us the service, location, property type, and timing window. We will come back with a practical next step rather than a vague one-line reply."
    backgroundImage="/images/areas/team-on-site-darwin-03.jpg"
    secondaryLabel="Browse Areas"
    secondaryHref="/areas"
  />

  <Section>
    <Breadcrumbs items={breadcrumbs} />
    <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
      <div class="surface-card space-y-5 p-8">
        <h2 class="text-3xl font-semibold">Get in touch</h2>
        <p>We support Darwin homes, offices, strata properties, specialist cleaning scopes, and urgent response work. The more detail you share, the faster we can point you to the right service.</p>
        <div class="space-y-3 text-sm">
          <p class="flex items-start gap-3">
            <Icon name="phone" size={16} class="mt-0.5 text-[var(--color-primary-700)]" />
            <span><strong>Phone:</strong> <a href={`tel:${site.phone}`}>{site.displayPhone}</a></span>
          </p>
          <p class="flex items-start gap-3">
            <Icon name="mail" size={16} class="mt-0.5 text-[var(--color-primary-700)]" />
            <span><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></span>
          </p>
          <p class="flex items-start gap-3">
            <Icon name="map-pin" size={16} class="mt-0.5 text-[var(--color-primary-700)]" />
            <span><strong>Service area:</strong> {site.serviceAreaSummary}</span>
          </p>
        </div>
        <div class="rounded-[1rem] bg-blue-50 p-5 text-sm text-blue-900">
          <div class="mb-2 inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-white text-[var(--color-primary-700)]">
            <Icon name="shield" size={18} />
          </div>
          For emergency or sensitive cleaning, include the urgency, site type, and access restrictions so we can triage the request properly.
        </div>
      </div>
      <ContactForm services={services} locations={locations} />
    </div>
  </Section>

  <MapEmbed
    eyebrow="Darwin map"
    heading="Find our Darwin service area"
    body="This Darwin location map gives you a quick view of the main area we cover before you send through your suburb, property type, and preferred service."
  />

  <Section eyebrow="FAQs" title="Questions about getting in touch" intro="Answers to common questions about quotes, response times, and booking." tone="alt">
    <FAQAccordion items={contactFaqs} />
  </Section>

  <CTASection
    title="Need to review services or Darwin locations before booking?"
    body="You can explore our full service list and local area pages first, then come back when you are ready to request a quote."
    primaryHref="/services"
    primaryLabel="View Services"
    secondaryHref="/areas"
    secondaryLabel="Browse Areas"
  />
</BaseLayout>
