---
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import FAQSchema from '@/components/schema/FAQSchema.astro';
import CTASection from '@/components/site/CTASection.astro';
import Breadcrumbs from '@/components/site/Breadcrumbs.astro';
import FAQAccordion from '@/components/site/FAQAccordion.astro';
import MapEmbed from '@/components/site/MapEmbed.astro';
import PageHero from '@/components/site/PageHero.astro';
import Section from '@/components/ui/Section.astro';
import { site } from '@/data/site';
import BaseLayout from '@/layouts/BaseLayout.astro';

const breadcrumbs = [
  { name: 'Home', path: '/' },
  { name: 'About', path: '/about' },
];
const aboutFaqs = [
  {
    question: `What does ${site.name} actually do?`,
    answer:
      `${site.name} is a Darwin-based cleaning company covering residential, commercial, specialist, and urgent-response cleaning. The business is structured around detailed service pages, clearer scope setting, and local planning that reflects how Darwin homes, offices, and managed buildings actually operate.`,
  },
  {
    question: 'What parts of Darwin do you serve?',
    answer:
      'We cover Darwin City, Parap, Nightcliff, Casuarina, Karama, Winnellie, Fannie Bay, Marrara, and nearby suburbs across the wider Darwin service area. Every location page includes local detail instead of generic city-wide copy.',
  },
  {
    question: 'Is the team insured and vetted?',
    answer:
      'Yes. Team members are vetted before site work and the business carries public liability coverage for residential, commercial, and specialist cleaning scopes.',
  },
  {
    question: 'What makes this company different from other Darwin cleaners?',
    answer:
      'The difference is the level of scope detail. We build service pages and local pages that explain what is included, what changes pricing, how Darwin access conditions affect the job, and where seasonal issues like humidity, storm runoff, dust, or short turnover windows change the method.',
  },
  {
    question: 'Do you offer both one-off and ongoing cleaning contracts?',
    answer:
      'Yes. We support one-off deep cleans, move-out cleans, post-construction cleans, and also set up weekly, fortnightly, or monthly maintenance programs for homes and commercial spaces.',
  },
];
---

<BaseLayout
  title="About Cleaning Company Darwin"
  description="Learn how Cleaning Company Darwin approaches residential, commercial, and specialist cleaning across Darwin with clear scopes and dependable service."
  path="/about"
  showGlobalMap={false}
>
  <Fragment slot="schema">
    <LocalBusinessSchema />
    <BreadcrumbSchema items={breadcrumbs} />
    <FAQSchema items={aboutFaqs} />
  </Fragment>

  <PageHero
    eyebrow="About us"
    title="A Darwin cleaning company built around clarity, detail, and trust"
    body="Cleaning Company Darwin is positioned as a full-scope cleaning partner for Darwin households, commercial sites, strata properties, and specialist environments that need more than a generic checklist."
    backgroundImage="/images/areas/team-on-site-darwin-01.jpg"
    backgroundImagePositionClass="object-center"
    secondaryLabel="Contact Us"
    secondaryHref="/contact"
  />

  <Section>
    <Breadcrumbs items={breadcrumbs} />
    <div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
      <div class="surface-card p-8">
        <h2 class="text-3xl font-semibold">Why the business exists</h2>
        <p class="mt-4">A lot of local cleaning sites either collapse everything into one thin page or publish dozens of near-duplicate area pages with nothing useful on them. Cleaning Company Darwin takes the opposite route: broad service capability, detailed service pages, and location pages that explain how Darwin properties actually behave.</p>
        <p class="mt-4">That matters for homes, offices, short-stay properties, and specialist sites because winter residue, dry-air dust, condo access rules, HOA expectations, and neighborhood parking all change how the job should be scoped. The goal is simple: make the service feel dependable before the cleaner even arrives.</p>
      </div>
      <div class="surface-card p-8">
        <h2 class="text-3xl font-semibold">Brand promise</h2>
        <ul class="mt-4 list-disc space-y-3 pl-5">
          <li>Show up on time and properly equipped.</li>
          <li>Set a clear standard before the visit starts.</li>
          <li>Use methods that fit the surface, not a generic routine.</li>
          <li>Communicate clearly before, during, and after the job.</li>
          <li>Leave spaces healthier, safer, and presentation-ready.</li>
        </ul>
      </div>
    </div>
  </Section>

  <Section eyebrow="What makes us different" title="Practical strengths clients notice quickly" tone="alt">
    <div class="grid gap-6 md:grid-cols-2">
      <div class="surface-card p-8">
        <h2 class="text-2xl font-semibold">One brand across many scopes</h2>
        <p class="mt-3">Residential cleaning, commercial programs, high-detail surface care, hygiene servicing, external washing, restoration, and sensitive response work all sit under the same operating logic. That means fewer handoffs and less confusion when a property needs more than one service line.</p>
      </div>
      <div class="surface-card p-8">
        <h2 class="text-2xl font-semibold">Locally relevant content and planning</h2>
        <p class="mt-3">Darwin homes and facilities are shaped by wet-season moisture, build-up humidity, dry-season dust, coastal salt, and shared building access rules. We use that context in both the site content and the service planning so the booking process feels more grounded and useful.</p>
      </div>
    </div>
  </Section>

  <MapEmbed
    eyebrow="Darwin location"
    heading="Serving Darwin and nearby suburbs"
    body="The map anchors our Darwin service area visually, while the area pages break the city into practical local routes for bookings, access planning, and suburb-specific advice."
  />

  <Section eyebrow="FAQs" title="Questions about the company" intro="Common questions from customers before they book.">
    <FAQAccordion items={aboutFaqs} />
  </Section>

  <CTASection
    title="Need a service plan that fits your property type and location?"
    body="Talk to us about the cleaning outcome you need, the location, and any access issues, and we will point you to the right service path."
  />
</BaseLayout>
