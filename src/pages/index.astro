---
import CTASection from '@/components/site/CTASection.astro';
import LocalBusinessSchema from '@/components/schema/LocalBusinessSchema.astro';
import LocationCard from '@/components/site/LocationCard.astro';
import MapEmbed from '@/components/site/MapEmbed.astro';
import PageHero from '@/components/site/PageHero.astro';
import ServiceCard from '@/components/site/ServiceCard.astro';
import Icon from '@/components/ui/Icon.astro';
import Section from '@/components/ui/Section.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ReviewsSection from '@/components/site/ReviewsSection.astro';
import FAQAccordion from '@/components/site/FAQAccordion.astro';
import FAQSchema from '@/components/schema/FAQSchema.astro';
import { getFeaturedLocations } from '@/data/locations';
import { site } from '@/data/site';
import { getFeaturedServices } from '@/data/services';

const featuredServices = getFeaturedServices(site.featuredServiceSlugs);
const featuredLocations = getFeaturedLocations(site.featuredLocationSlugs);
const processSteps = [
  ['message-square', 'Request a quote', 'Tell us the property type, location, and the outcome you need.'],
  ['clipboard', 'Confirm the scope', 'We set the service details, timing window, and any add-ons clearly before the visit.'],
  ['sparkles', 'We clean', 'Our team works through the agreed checklist with the right tools for the space.'],
  ['check-circle', 'Enjoy the result', 'You get a cleaner, safer, presentation-ready space with clear follow-up advice.'],
];
const homeFaqs = [
  {
    question: `What types of cleaning does ${site.name} offer?`,
    answer:
      'We cover recurring house cleaning, deep cleaning, move-in and move-out cleaning, office cleaning, short-stay turnover cleaning, carpet and floor care, window cleaning, pressure washing, mould remediation, and other specialist cleaning services across Darwin and nearby suburbs.',
  },
  {
    question: 'How do I get a quote for a cleaning job in Darwin?',
    answer:
      'Use the quote form on the Contact page or call us with the property type, neighborhood, service needed, and preferred timing window. We respond with a clear scope, not a generic one-line estimate, so you know what is included before booking.',
  },
  {
    question: 'Which Darwin suburbs do you serve?',
    answer:
      'We cover Darwin City (CBD), Parap, Nightcliff, Casuarina, Karama, Winnellie, Fannie Bay, Marrara, and nearby suburbs. The area pages explain postcode coverage, local access considerations, and nearby service options.',
  },
  {
    question: 'Are your cleaners insured and vetted?',
    answer:
      'Yes. We operate with public liability coverage and vet team members before assigning them to residential, commercial, and specialist cleaning work.',
  },
  {
    question: 'Can I book a one-off clean or do I need a regular contract?',
    answer:
      'Both. We handle one-off cleans such as move-out, post-renovation, and deep seasonal resets, as well as weekly, fortnightly, or monthly recurring programs for homes and commercial properties.',
  },
  {
    question: 'How do Darwin seasons affect cleaning schedules?',
    answer:
      'Darwin weather changes the cleaning workload more than most people expect. Wet season brings mud, moisture, and fast entryway buildup, the build-up pushes humidity and mould pressure higher, and the dry season adds dust, salt haze, and more open-window debris. We adjust timing and methods around those conditions.',
  },
];
---

<BaseLayout
  title="Cleaning Company Darwin"
  description="Professional cleaning company in Darwin for homes, offices, specialist cleans, and urgent response work. Request a free quote today."
  path="/"
  showGlobalMap={false}
>
  <Fragment slot="schema">
    <LocalBusinessSchema />
    <FAQSchema items={homeFaqs} />
  </Fragment>

  <PageHero
    eyebrow="Darwin cleaning company"
    title="Professional Cleaning Company in Darwin"
    body="Cleaning Company Darwin delivers residential, commercial, specialist, and emergency cleaning across Darwin with practical scopes, polished presentation, and dependable communication."
    primaryLabel="Request a Free Quote"
    primaryHref="/contact"
    secondaryLabel="Call Now — Free Estimate"
    secondaryHref={`tel:${site.phone}`}
    backgroundImage="/images/branding/hero-home-darwin-cleaning-01.jpg"
  />

  <Section eyebrow="Why choose us" title="A cleaner, calmer service experience" intro="We built the site and service model to answer the gaps competitors leave behind: clearer scope, more local detail, stronger service depth, and fewer vague promises.">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      <div class="surface-card p-6">
        <h2 class="text-xl font-semibold">One provider, broad capability</h2>
        <p class="mt-3">Routine house cleaning, specialist surfaces, compliance-sensitive facilities, and urgent response work can sit under one coordinated brand.</p>
      </div>
      <div class="surface-card p-6">
        <h2 class="text-xl font-semibold">Darwin-aware cleaning plans</h2>
        <p class="mt-3">Wet-season grime, build-up humidity, coastal salt, parking limits, and apartment access rules all change how cleaning should be scoped here.</p>
      </div>
      <div class="surface-card p-6">
        <h2 class="text-xl font-semibold">Clear scopes and better detail</h2>
        <p class="mt-3">We describe what is included, what changes the price, and where add-ons are worth it before the visit starts.</p>
      </div>
      <div class="surface-card p-6">
        <h2 class="text-xl font-semibold">Residential to regulated sites</h2>
        <p class="mt-3">Homes, strata, offices, hospitality, healthcare-adjacent work, and specialist remediation all have service pathways here.</p>
      </div>
    </div>
  </Section>

  <Section eyebrow="Featured services" title="Start with the service category that fits your job" intro="The full site covers 146 service pages, but these are the pages most users start with when they need Darwin-specific help quickly." tone="alt">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {featuredServices.map((service) => <ServiceCard service={service} />)}
    </div>
  </Section>

  <Section eyebrow="Service areas" title="Built for Darwin locations, not generic city-wide copy" intro="Each area page includes postcode coverage, nearby landmarks, local cleaning conditions, and the services most relevant to that part of Darwin and nearby suburbs.">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {featuredLocations.map((location) => <LocationCard location={location} />)}
    </div>
  </Section>

  <Section eyebrow="How it works" title="A simple process that still feels thorough" intro="The job should be easy to understand before anyone arrives on site. That is especially important for handovers, recurring commercial work, and higher-risk cleaning scopes." tone="alt">
    <div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
      {processSteps.map(([icon, title, body], index) => (
        <div class="surface-card p-6">
          <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-blue-50 text-[var(--color-primary-700)]">
            <Icon name={icon as 'message-square' | 'clipboard' | 'sparkles' | 'check-circle'} size={18} />
          </span>
          <p class="text-sm font-semibold uppercase tracking-[0.24em] text-blue-700">Step {index + 1}</p>
          <h2 class="mt-4 text-2xl font-semibold">{title}</h2>
          <p class="mt-3">{body}</p>
        </div>
      ))}
    </div>
  </Section>

  <MapEmbed
    eyebrow="Darwin coverage"
    heading="Darwin cleaning coverage map"
    body="Use the map to view our Darwin service area hub. We support homes, offices, short-stay properties, and specialist cleaning work across Darwin CBD and nearby suburbs."
  />

  <ReviewsSection />

  <Section eyebrow="FAQs" title="Common questions about Darwin cleaning services" intro="Quick answers to the questions our customers ask most before booking." tone="alt">
    <FAQAccordion items={homeFaqs} />
  </Section>

  <CTASection
    title="Need a Darwin cleaning team that can handle more than one type of job?"
    body="Tell us the service, location, and timing window and we will map out a practical next step, whether you need recurring home cleaning, a specialist reset, or urgent support."
    primaryHref="/contact"
    secondaryHref="/areas"
    secondaryLabel="Browse Service Areas"
  />
</BaseLayout>
