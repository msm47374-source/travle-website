---
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import Icon from '@/components/ui/Icon.astro';
import type { LocationRecord } from '@/data/types';

interface Props {
  location: LocationRecord;
}

const { location } = Astro.props;
---

<Card class="flex h-full flex-col gap-5">
  <img
    src={location.image.src}
    alt={location.image.alt}
    width={location.image.width}
    height={location.image.height}
    class="rounded-[1rem] border border-slate-200 object-cover"
    loading="lazy"
  />
  <div class="space-y-3">
    <div class="flex items-center">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-emerald-50 text-emerald-700">
        <Icon name="map-pin" size={18} />
      </span>
    </div>
    <h3 class="text-2xl font-semibold">{location.name}</h3>
    <p>{location.localInsight}</p>
  </div>
  <div class="mt-auto">
    <Button href={`/areas/${location.slug}`} variant="secondary" iconRight="arrow-right">
      Explore area
    </Button>
  </div>
</Card>
