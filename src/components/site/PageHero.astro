---
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Container from '@/components/ui/Container.astro';
import TrustBar from '@/components/site/TrustBar.astro';
import { site } from '@/data/site';

interface Props {
  eyebrow?: string;
  title: string;
  body: string;
  primaryLabel?: string;
  primaryHref?: string;
  secondaryLabel?: string;
  secondaryHref?: string;
  backgroundImage?: string;
  backgroundImagePositionClass?: string;
  visualImage?: string;
  visualAlt?: string;
}

const {
  eyebrow,
  title,
  body,
  primaryLabel = 'Get a Free Quote',
  primaryHref = '/contact',
  backgroundImage,
  backgroundImagePositionClass = 'object-[72%_center]',
  visualImage = '/images/branding/hero-home-darwin-cleaning-01.jpg',
  visualAlt = 'Professional cleaning team preparing a bright Darwin property',
} = Astro.props;

const secondaryLabel = 'Call Now — Free Estimate';
const secondaryHref = `tel:${site.phone}`;
---

<section
  class:list={[
    'relative overflow-hidden border-b border-slate-200 bg-[linear-gradient(180deg,rgba(248,250,252,1),rgba(255,255,255,1))] py-16 md:py-24',
    backgroundImage && 'lg:min-h-[34rem] lg:py-20',
  ]}
>
  {backgroundImage && (
    <>
      <div class="absolute inset-0">
        <img
          src={backgroundImage}
          alt=""
          width="1792"
          height="1024"
          class:list={['h-full w-full object-cover', backgroundImagePositionClass]}
          aria-hidden="true"
        />
      </div>
      <div
        class="absolute inset-0 bg-[linear-gradient(110deg,rgba(15,23,42,0.14),rgba(15,23,42,0.05)_42%,rgba(15,23,42,0.1))]"
        aria-hidden="true"
      ></div>
    </>
  )}

  <Container
    class:list={[
      'relative',
      backgroundImage
        ? 'lg:grid lg:min-h-[28rem] lg:grid-cols-[minmax(0,0.58fr)_minmax(0,0.42fr)] lg:items-center lg:gap-10'
        : 'grid items-center gap-10 lg:grid-cols-[1.2fr_0.8fr]',
    ]}
  >
    <div
      class:list={[
        backgroundImage &&
          'surface-card max-w-[42rem] border-white/55 bg-white/78 p-7 shadow-[0_24px_60px_rgba(15,23,42,0.16)] backdrop-blur-md md:p-10 lg:max-w-[40rem] xl:max-w-[42rem]',
      ]}
    >
      {eyebrow && <Badge class="mb-4">{eyebrow}</Badge>}
      <h1 class="max-w-4xl text-4xl font-semibold md:text-6xl">{title}</h1>
      <p class="mt-6 max-w-2xl text-lg text-slate-600 md:text-xl">{body}</p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <Button href={primaryHref} iconRight="arrow-right">{primaryLabel}</Button>
        <Button href={secondaryHref} variant="secondary" iconLeft="phone">{secondaryLabel}</Button>
      </div>
    </div>
    {backgroundImage && <div class="hidden lg:block" aria-hidden="true"></div>}
    {!backgroundImage && (
      <div class="surface-card overflow-hidden p-4">
        <img
          src={visualImage}
          alt={visualAlt}
          width="1792"
          height="1024"
          class="rounded-[1rem] object-cover"
        />
      </div>
    )}
  </Container>
</section>

<TrustBar />
