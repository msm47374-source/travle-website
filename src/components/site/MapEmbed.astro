---
import Section from '@/components/ui/Section.astro';
import { site } from '@/data/site';

interface Props {
  heading: string;
  body: string;
  eyebrow?: string;
}

const { heading, body, eyebrow = 'Service map' } = Astro.props;
---

<Section eyebrow={eyebrow} title={heading} intro={body} class="pb-10">
  <div class="overflow-hidden rounded-[1.25rem] border border-slate-200 shadow-[var(--shadow-md)]">
    <iframe
      src={site.mapEmbedUrl}
      width="100%"
      height="400"
      style="border:0;border-radius:12px"
      allowfullscreen
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title={heading}
    ></iframe>
  </div>
</Section>
