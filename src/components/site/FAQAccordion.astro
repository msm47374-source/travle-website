---
import type { FaqItem } from '@/data/types';

interface Props {
  items: FaqItem[];
  class?: string;
}

const { items, class: className } = Astro.props;
---

<div class={`faq-list ${className ?? ''}`}>
  {items.map((item, i) => (
    <div class="faq-item" id={`faq-${i}`}>
      <button
        class="faq-trigger"
        aria-expanded="false"
        aria-controls={`faq-panel-${i}`}
        type="button"
      >
        <span class="faq-question">{item.question}</span>
        <span class="faq-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 5v14M5 12h14" class="icon-plus" />
            <path d="M5 12h14" class="icon-minus" />
          </svg>
        </span>
      </button>
      <div class="faq-panel" id={`faq-panel-${i}`} role="region" aria-labelledby={`faq-${i}`}>
        <p class="faq-answer">{item.answer}</p>
      </div>
    </div>
  ))}
</div>

<style>
  /* ── List ───────────────────────────────────── */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* ── Item card ──────────────────────────────── */
  .faq-item {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    overflow: hidden;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .faq-item:has(.faq-trigger[aria-expanded="true"]) {
    border-color: #bfdbfe;
    box-shadow: 0 4px 18px rgba(37, 99, 235, 0.08);
  }

  /* ── Trigger button ─────────────────────────── */
  .faq-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
  }
  .faq-trigger:hover .faq-question {
    color: #1d4ed8;
  }

  /* ── Question text ──────────────────────────── */
  .faq-question {
    font-size: 1rem;
    font-weight: 600;
    color: #0f172a;
    line-height: 1.5;
    transition: color 0.15s;
  }

  /* ── Icon ───────────────────────────────────── */
  .faq-icon {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: #f1f5f9;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s, transform 0.3s;
  }
  .faq-icon svg {
    width: 16px;
    height: 16px;
    color: #475569;
    transition: color 0.2s;
  }
  .icon-minus {
    display: none;
  }

  /* open state */
  .faq-trigger[aria-expanded="true"] .faq-icon {
    background: #dbeafe;
    transform: rotate(45deg);
  }
  .faq-trigger[aria-expanded="true"] .faq-icon svg {
    color: #1d4ed8;
  }

  /* ── Panel ──────────────────────────────────── */
  .faq-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1), padding 0.2s;
    padding: 0 1.5rem;
  }
  .faq-panel.is-open {
    max-height: 600px;
    padding-bottom: 1.25rem;
  }

  /* ── Answer ─────────────────────────────────── */
  .faq-answer {
    font-size: 0.925rem;
    color: #475569;
    line-height: 1.75;
    margin: 0;
    border-top: 1px solid #f1f5f9;
    padding-top: 1rem;
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      const panelId = trigger.getAttribute('aria-controls');
      const panel = panelId ? document.getElementById(panelId) : null;

      // Close all in same list
      const list = trigger.closest('.faq-list');
      list?.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach((t) => {
        t.setAttribute('aria-expanded', 'false');
        const pid = t.getAttribute('aria-controls');
        if (pid) document.getElementById(pid)?.classList.remove('is-open');
      });

      // Open this one if it was closed
      if (!isOpen && panel) {
        trigger.setAttribute('aria-expanded', 'true');
        panel.classList.add('is-open');
      }
    });
  });
</script>
