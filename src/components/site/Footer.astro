---
import BrandLogo from '@/components/site/BrandLogo.astro';
import Container from '@/components/ui/Container.astro';
import Icon from '@/components/ui/Icon.astro';
import { getFeaturedLocations } from '@/data/locations';
import { site } from '@/data/site';
import { getFeaturedServices } from '@/data/services';

const featuredServices = getFeaturedServices(site.featuredServiceSlugs);
const featuredLocations = getFeaturedLocations(site.featuredLocationSlugs);
const socialIcons = {
  Facebook: 'facebook',
  Instagram: 'instagram',
  LinkedIn: 'linkedin',
} as const;
---

<footer class="border-t border-slate-200 bg-slate-950 text-slate-200">
  <Container class="grid gap-10 py-14 md:grid-cols-[1.3fr_1fr_1fr]">
    <div class="space-y-4">
      <a href="/" aria-label={site.brandName} class="inline-flex">
        <BrandLogo variant="light" />
      </a>
      <p class="max-w-md text-slate-300">{site.tagline}</p>
      <p class="text-sm text-slate-400">{site.serviceAreaSummary}</p>
      <div class="space-y-3 text-sm text-slate-300">
        <p class="flex items-center gap-3">
          <Icon name="phone" size={16} class="text-blue-300" />
          <a href={`tel:${site.phone}`}>{site.displayPhone}</a>
        </p>
        <p class="flex items-center gap-3">
          <Icon name="mail" size={16} class="text-blue-300" />
          <a href={`mailto:${site.email}`}>{site.email}</a>
        </p>
        <p class="flex items-center gap-3">
          <Icon name="map-pin" size={16} class="text-blue-300" />
          <span>{site.address.addressLocality}, {site.address.addressRegion} {site.address.postalCode}</span>
        </p>
      </div>
      <div class="flex flex-wrap gap-3 pt-2">
        {site.socialLinks.map((item) => (
          <a
            href={item.href}
            class="inline-flex items-center gap-2 rounded-full border border-slate-800 px-3 py-2 text-sm text-slate-300 transition hover:border-slate-600 hover:text-white"
          >
            <Icon name={socialIcons[item.label as keyof typeof socialIcons]} size={15} />
            {item.label}
          </a>
        ))}
      </div>
      </div>
    </div>

    <div>
      <h3 class="mb-4 flex items-center gap-2 text-lg font-semibold text-white">
        <Icon name="sparkles" size={18} class="text-blue-300" />
        Top Services
      </h3>
      <ul class="space-y-3 text-sm">
        {featuredServices.map((service) => (
          <li><a href={`/services/${service.slug}`} class="text-slate-300 hover:text-white">{service.name}</a></li>
        ))}
      </ul>
    </div>

    <div>
      <h3 class="mb-4 flex items-center gap-2 text-lg font-semibold text-white">
        <Icon name="map-pin" size={18} class="text-blue-300" />
        Top Areas
      </h3>
      <ul class="space-y-3 text-sm">
        {featuredLocations.map((location) => (
          <li><a href={`/areas/${location.slug}`} class="text-slate-300 hover:text-white">{location.name}</a></li>
        ))}
      </ul>
    </div>
  </Container>
</footer>
