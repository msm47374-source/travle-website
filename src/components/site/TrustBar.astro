---
// TrustBar.astro – horizontal strip of trust signals
---

<div class="trust-bar">
  <div class="trust-inner">

    <!-- 4.9/5 Reviews -->
    <div class="trust-item">
      <span class="trust-icon trust-icon--yellow" aria-hidden="true">
        <!-- Star -->
        <svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
        </svg>
      </span>
      <div>
        <p class="trust-value">4.9<span class="trust-denom">/5</span></p>
        <p class="trust-label">200+ Reviews</p>
      </div>
    </div>

    <div class="trust-divider" aria-hidden="true"></div>

    <!-- Licensed -->
    <div class="trust-item">
      <span class="trust-icon trust-icon--green" aria-hidden="true">
        <!-- Shield check -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          <polyline points="9 12 11 14 15 10"/>
        </svg>
      </span>
      <div>
        <p class="trust-value">Licensed</p>
        <p class="trust-label">Fully Insured</p>
      </div>
    </div>

    <div class="trust-divider" aria-hidden="true"></div>

    <!-- Jobs Completed -->
    <div class="trust-item">
      <span class="trust-icon trust-icon--blue" aria-hidden="true">
        <!-- Truck / spray bottle -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
          <rect x="1" y="3" width="15" height="13" rx="2"/>
          <path d="M16 8h4l3 5v3h-7V8z"/>
          <circle cx="5.5" cy="18.5" r="2.5"/>
          <circle cx="18.5" cy="18.5" r="2.5"/>
        </svg>
      </span>
      <div>
        <p class="trust-value">5,000+</p>
        <p class="trust-label">Jobs Completed</p>
      </div>
    </div>

    <div class="trust-divider" aria-hidden="true"></div>

    <!-- Years -->
    <div class="trust-item">
      <span class="trust-icon trust-icon--orange" aria-hidden="true">
        <!-- Clock -->
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" width="22" height="22">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </span>
      <div>
        <p class="trust-value">10+ <span class="trust-denom">Yrs</span></p>
        <p class="trust-label">In Darwin Service Area</p>
      </div>
    </div>

  </div>
</div>

<style>
  .trust-bar {
    background: #fff;
    border-top: 1px solid #e2e8f0;
    border-bottom: 1px solid #e2e8f0;
    padding: 1.1rem 1.5rem;
  }

  .trust-inner {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
  }

  /* ── Each stat ───────────────────────────────────── */
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.5rem 2rem;
    flex: 1 0 auto;
    justify-content: center;
  }

  /* ── Icon bubble ─────────────────────────────────── */
  .trust-icon {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .trust-icon--yellow { background: #fef9c3; color: #ca8a04; }
  .trust-icon--green  { background: #dcfce7; color: #16a34a; }
  .trust-icon--blue   { background: #dbeafe; color: #1d4ed8; }
  .trust-icon--orange { background: #ffedd5; color: #ea580c; }

  /* ── Text ────────────────────────────────────────── */
  .trust-value {
    font-size: 1.05rem;
    font-weight: 700;
    color: #0f172a;
    margin: 0;
    line-height: 1.25;
  }
  .trust-denom {
    font-size: 0.8rem;
    font-weight: 500;
    color: #64748b;
  }
  .trust-label {
    font-size: 0.78rem;
    color: #64748b;
    margin: 0;
    line-height: 1.3;
  }

  /* ── Dividers ────────────────────────────────────── */
  .trust-divider {
    width: 1px;
    height: 36px;
    background: #e2e8f0;
    flex-shrink: 0;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 640px) {
    .trust-item {
      padding: 0.4rem 1rem;
      flex: 0 0 calc(50% - 1px);
    }
    .trust-divider {
      display: none;
    }
    .trust-inner {
      gap: 0.5rem;
    }
  }
</style>
