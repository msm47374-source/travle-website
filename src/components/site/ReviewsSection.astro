---
// ReviewsSection.astro
// Matches the "What Our Customers Say" design with Google Reviews badge + review card carousel

interface Review {
  name: string;
  initials: string;
  timeAgo: string;
  stars: number;
  tags: string[];
  quote: string;
}

const reviews: Review[] = [
  {
    name: 'Sarah Mitchell',
    initials: 'S',
    timeAgo: '2 weeks ago',
    stars: 5,
    tags: ['House Clean', 'Cherry Creek'],
    quote:
      '"Absolutely fantastic service. The team arrived on time, cleaned every corner of our home with real attention to detail, and helped us get settled before family arrived for the weekend. Our Cherry Creek place looked better than it has in months."',
  },
  {
    name: 'James Nguyen',
    initials: 'J',
    timeAgo: '1 month ago',
    stars: 5,
    tags: ['Office Clean', 'Darwin CBD'],
    quote:
      '"They handled our office reset over the weekend without any issues. More than 50 workstations, shared kitchens, and glass partitions were cleaned on schedule, and the communication was excellent from start to finish."',
  },
  {
    name: 'Emily Robertson',
    initials: 'E',
    timeAgo: '3 weeks ago',
    stars: 5,
    tags: ['Move-Out Clean', 'Capitol Hill'],
    quote:
      '"Move-out cleaning is stressful, but the team made it straightforward. They handled the kitchen, bathroom detail, and all the small inspection items our property manager usually flags. The handover felt under control instead of rushed."',
  },
  {
    name: 'David Chen',
    initials: 'D',
    timeAgo: '5 days ago',
    stars: 5,
    tags: ['Deep Clean', 'Lakewood'],
    quote:
      '"We booked a deep clean for our Lakewood home after winter and the difference was obvious right away. Entryways, baseboards, bathrooms, and dust-heavy rooms all came up properly, and the team was punctual and thorough."',
  },
  {
    name: 'Rachel Torres',
    initials: 'R',
    timeAgo: '2 months ago',
    stars: 5,
    tags: ['Specialist Clean', 'Aurora'],
    quote:
      '"They handled a specialist mould cleanup in our lower-level bathroom and explained the process clearly the whole way through. The result was excellent, and it felt like they were solving the actual problem rather than just wiping the surface."',
  },
];
---

<section class="reviews-section">
  <div class="reviews-container">
    <!-- Heading -->
    <div class="reviews-heading">
      <h2 class="reviews-title">What Our Customers Say</h2>
      <p class="reviews-subtitle">Real reviews from real customers. We take pride in every clean.</p>
    </div>

    <!-- Google Rating Badge -->
    <div class="reviews-badge-wrapper">
      <div class="reviews-badge">
        <div class="badge-rating-row">
          <span class="badge-score">4.9</span>
          <div class="badge-stars">
            {Array.from({ length: 5 }).map(() => (
              <svg class="star-icon" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
        </div>
        <p class="badge-count">Based on 200+ reviews</p>
        <div class="badge-google">
          <!-- Google G logo SVG -->
          <svg class="google-icon" viewBox="0 0 48 48" aria-hidden="true">
            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            <path fill="none" d="M0 0h48v48H0z"/>
          </svg>
          <span class="badge-google-text">Google Reviews</span>
        </div>
      </div>
    </div>

    <!-- Reviews Carousel -->
    <div class="reviews-track-wrapper">
      <div class="reviews-track" id="reviewsTrack">
        {reviews.map((review) => (
          <div class="review-card">
            <!-- Card Header -->
            <div class="review-card-header">
              <div class="review-avatar" aria-hidden="true">{review.initials}</div>
              <div class="review-meta">
                <div class="review-name-row">
                  <span class="review-name">{review.name}</span>
                  <span class="review-verified">
                    <svg viewBox="0 0 16 16" fill="currentColor" class="verified-icon" aria-hidden="true">
                      <path fill-rule="evenodd" d="M8 1.5a6.5 6.5 0 100 13 6.5 6.5 0 000-13zM0 8a8 8 0 1116 0A8 8 0 010 8zm11.78-1.72a.75.75 0 00-1.06-1.06L7 8.94 5.28 7.22a.75.75 0 00-1.06 1.06l2.25 2.25a.75.75 0 001.06 0l4.25-4.25z" clip-rule="evenodd"/>
                    </svg>
                    Verified
                  </span>
                </div>
                <div class="review-source-row">
                  <svg class="google-icon-sm" viewBox="0 0 48 48" aria-hidden="true">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
                    <path fill="none" d="M0 0h48v48H0z"/>
                  </svg>
                  <span class="review-time">{review.timeAgo}</span>
                </div>
              </div>
            </div>

            <!-- Stars -->
            <div class="review-stars" aria-label={`${review.stars} out of 5 stars`}>
              {Array.from({ length: review.stars }).map(() => (
                <svg class="star-icon star-sm" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                </svg>
              ))}
            </div>

            <!-- Tags -->
            <div class="review-tags">
              {review.tags.map((tag) => (
                <span class="review-tag">{tag}</span>
              ))}
            </div>

            <!-- Quote -->
            <p class="review-quote">{review.quote}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Carousel Dots + Arrows -->
    <div class="carousel-controls">
      <button class="carousel-btn" id="reviewsPrev" aria-label="Previous reviews">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <div class="carousel-dots" id="reviewsDots" role="tablist" aria-label="Review slides">
        {reviews.map((_, i) => (
          <button
            class={`dot ${i === 0 ? 'dot-active' : ''}`}
            data-index={i}
            aria-label={`Go to slide ${i + 1}`}
            role="tab"
            aria-selected={i === 0 ? 'true' : 'false'}
          />
        ))}
      </div>
      <button class="carousel-btn" id="reviewsNext" aria-label="Next reviews">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</section>

<style>
  /* ── Section wrapper ─────────────────────────────── */
  .reviews-section {
    padding: 4rem 1rem 5rem;
    background: #fff;
  }
  .reviews-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ── Heading ─────────────────────────────────────── */
  .reviews-heading {
    text-align: center;
    margin-bottom: 2.25rem;
  }
  .reviews-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 0.5rem;
  }
  .reviews-subtitle {
    font-size: 1rem;
    color: #64748b;
    margin: 0;
  }

  /* ── Google rating badge ─────────────────────────── */
  .reviews-badge-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 3rem;
  }
  .reviews-badge {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 16px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.07);
    padding: 1.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    min-width: 220px;
  }
  .badge-rating-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .badge-score {
    font-size: 2.75rem;
    font-weight: 800;
    color: #0f172a;
    line-height: 1;
  }
  .badge-stars {
    display: flex;
    gap: 2px;
  }
  .star-icon {
    width: 20px;
    height: 20px;
    color: #f59e0b;
  }
  .star-sm {
    width: 17px;
    height: 17px;
  }
  .badge-count {
    font-size: 0.82rem;
    color: #64748b;
    margin: 0;
  }
  .badge-google {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }
  .google-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
  .google-icon-sm {
    width: 14px;
    height: 14px;
    flex-shrink: 0;
  }
  .badge-google-text {
    font-size: 0.9rem;
    font-weight: 500;
    color: #374151;
  }

  /* ── Carousel track ──────────────────────────────── */
  .reviews-track-wrapper {
    overflow: hidden;
  }
  .reviews-track {
    display: flex;
    gap: 1.25rem;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }

  /* ── Review card ─────────────────────────────────── */
  .review-card {
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
    padding: 1.5rem;
    flex: 0 0 calc(33.333% - 0.84rem);
    min-width: 280px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .review-card:hover {
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.11);
    transform: translateY(-2px);
  }

  /* ── Card header ─────────────────────────────────── */
  .review-card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .review-avatar {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: #dbeafe;
    color: #1d4ed8;
    font-weight: 700;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .review-meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .review-name-row {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    flex-wrap: wrap;
  }
  .review-name {
    font-weight: 600;
    font-size: 0.92rem;
    color: #0f172a;
  }
  .review-verified {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.72rem;
    font-weight: 600;
    color: #059669;
    background: #d1fae5;
    padding: 2px 7px;
    border-radius: 99px;
  }
  .verified-icon {
    width: 11px;
    height: 11px;
    color: #059669;
  }
  .review-source-row {
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }
  .review-time {
    font-size: 0.78rem;
    color: #94a3b8;
  }

  /* ── Stars ───────────────────────────────────────── */
  .review-stars {
    display: flex;
    gap: 2px;
  }

  /* ── Tags ────────────────────────────────────────── */
  .review-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .review-tag {
    font-size: 0.72rem;
    font-weight: 500;
    color: #475569;
    background: #f1f5f9;
    border: 1px solid #e2e8f0;
    padding: 3px 10px;
    border-radius: 99px;
  }

  /* ── Quote ───────────────────────────────────────── */
  .review-quote {
    font-size: 0.88rem;
    color: #374151;
    line-height: 1.65;
    margin: 0;
  }

  /* ── Carousel controls ───────────────────────────── */
  .carousel-controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }
  .carousel-btn {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    border: 1px solid #e2e8f0;
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #374151;
    transition: background 0.2s, border-color 0.2s, color 0.2s;
  }
  .carousel-btn:hover {
    background: #1d4ed8;
    border-color: #1d4ed8;
    color: #fff;
  }
  .carousel-btn svg {
    width: 16px;
    height: 16px;
  }
  .carousel-dots {
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .dot {
    width: 8px;
    height: 8px;
    border-radius: 99px;
    background: #cbd5e1;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: width 0.25s ease, background 0.25s ease;
  }
  .dot-active {
    width: 22px;
    background: #1d4ed8;
  }

  /* ── Responsive ──────────────────────────────────── */
  @media (max-width: 900px) {
    .review-card {
      flex: 0 0 calc(50% - 0.63rem);
    }
  }
  @media (max-width: 600px) {
    .review-card {
      flex: 0 0 calc(100% - 0px);
    }
    .reviews-badge {
      padding: 1.25rem 1.75rem;
    }
  }
</style>

<script>
  // ── Carousel logic ───────────────────────────────────────────────
  (function () {
    const track = document.getElementById('reviewsTrack') as HTMLElement | null;
    const dotsContainer = document.getElementById('reviewsDots') as HTMLElement | null;
    const prevBtn = document.getElementById('reviewsPrev') as HTMLButtonElement | null;
    const nextBtn = document.getElementById('reviewsNext') as HTMLButtonElement | null;

    if (!track || !dotsContainer || !prevBtn || !nextBtn) return;

    const cards = track.querySelectorAll<HTMLElement>('.review-card');
    const dots = dotsContainer.querySelectorAll<HTMLButtonElement>('.dot');
    let current = 0;

    function visibleCount(): number {
      const w = window.innerWidth;
      if (w >= 900) return 3;
      if (w >= 600) return 2;
      return 1;
    }

    function maxIndex(): number {
      return Math.max(0, cards.length - visibleCount());
    }

    function go(index: number) {
      current = Math.max(0, Math.min(index, maxIndex()));
      const firstCard = cards[0];
      if (!firstCard) return;
      const cardWidth = firstCard.offsetWidth + 20; // gap = 1.25rem ~= 20px
      track?.style.setProperty("transform", `translateX(-${current * cardWidth}px)`);

      dots.forEach((d, i) => {
        const active = i === current;
        d.classList.toggle('dot-active', active);
        d.setAttribute('aria-selected', active ? 'true' : 'false');
      });
    }

    prevBtn.addEventListener('click', () => go(current - 1));
    nextBtn.addEventListener('click', () => go(current + 1));

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => go(i));
    });

    window.addEventListener('resize', () => go(Math.min(current, maxIndex())));
  })();
</script>


