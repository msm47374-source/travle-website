---
import Card from '@/components/ui/Card.astro';
import Icon from '@/components/ui/Icon.astro';
import type { Testimonial } from '@/data/types';

interface Props {
  items: Testimonial[];
}

const { items } = Astro.props;
---

<div class="flex snap-x gap-6 overflow-x-auto pb-2">
  {items.map((item) => (
    <Card class="min-w-[320px] max-w-md snap-start">
      <span class="inline-flex h-11 w-11 items-center justify-center rounded-2xl bg-blue-50 text-[var(--color-primary-700)]">
        <Icon name="quote" size={18} />
      </span>
      <p class="text-lg leading-8 text-slate-800">"{item.quote}"</p>
      <div class="mt-6">
        <p class="font-semibold text-slate-900">{item.name}</p>
        <p class="text-sm text-slate-500">{item.role}</p>
      </div>
    </Card>
  ))}
</div>
