---
import Icon from '@/components/ui/Icon.astro';
import { site } from '@/data/site';
import { cn } from '@/lib/utils';

interface Props {
  variant?: 'light' | 'dark';
  class?: string;
  compact?: boolean;
}

const { variant = 'dark', class: className, compact = false } = Astro.props;

const iconWrapClass =
  variant === 'light'
    ? 'bg-white/10 text-white ring-1 ring-white/15'
    : 'bg-blue-50 text-[var(--color-primary-700)] ring-1 ring-blue-100';

const overlineClass = variant === 'light' ? 'text-slate-300' : 'text-slate-500';
const headlineClass = variant === 'light' ? 'text-white' : 'text-slate-950';

const lineOne = 'Cleaning Company';
const lineTwo = 'Darwin';
---

<span class={cn('inline-flex items-center gap-3', className)}>
  <span class:list={['inline-flex shrink-0 items-center justify-center rounded-2xl', compact ? 'h-11 w-11' : 'h-12 w-12', iconWrapClass]}>
    <Icon name="sparkles" size={compact ? 18 : 20} />
  </span>
  <span class="flex flex-col leading-none">
    <span class:list={['text-[0.68rem] font-semibold uppercase tracking-[0.28em]', overlineClass]}>
      {lineOne}
    </span>
    <span class:list={['mt-1 font-semibold uppercase tracking-[0.08em]', compact ? 'text-lg' : 'text-xl', headlineClass]}>
      {lineTwo}
    </span>
    <span class="sr-only">{site.brandName}</span>
  </span>
</span>
