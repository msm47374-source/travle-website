---
import Badge from '@/components/ui/Badge.astro';
import Button from '@/components/ui/Button.astro';
import Card from '@/components/ui/Card.astro';
import Icon from '@/components/ui/Icon.astro';
import type { ServiceRecord } from '@/data/types';

interface Props {
  service: ServiceRecord;
}

const { service } = Astro.props;
---

<Card class="flex h-full flex-col gap-5">
  <img
    src={service.image.src}
    alt={service.image.alt}
    width={service.image.width}
    height={service.image.height}
    class="rounded-[1rem] border border-slate-200 object-cover"
    loading="lazy"
  />
  <div class="space-y-3">
    <div class="flex items-center gap-3">
      <span class="inline-flex h-10 w-10 items-center justify-center rounded-2xl bg-blue-50 text-[var(--color-primary-700)]">
        <Icon name="sparkles" size={18} />
      </span>
      <Badge tone="neutral">{service.category}</Badge>
    </div>
    <h3 class="text-2xl font-semibold">{service.name}</h3>
    <p>{service.description}</p>
    <div class="rounded-[1rem] bg-blue-50 p-4">
      <p class="text-xs font-semibold uppercase tracking-[0.24em] text-blue-700">Pricing guide</p>
      <p class="mt-2 text-sm font-semibold text-blue-900">{service.priceRange}</p>
    </div>
  </div>
  <div class="mt-auto">
    <Button href={`/services/${service.slug}`} variant="secondary" iconRight="arrow-right">
      View service
    </Button>
  </div>
</Card>
