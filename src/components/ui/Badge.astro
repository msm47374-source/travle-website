---
import { cn } from '@/lib/utils';

interface Props {
  class?: string;
  tone?: 'primary' | 'accent' | 'neutral';
}

const { class: className, tone = 'primary' } = Astro.props;

const toneClasses = {
  primary: 'border-blue-200 bg-blue-50 text-blue-900',
  accent: 'border-green-200 bg-green-50 text-green-900',
  neutral: 'border-slate-200 bg-white text-slate-700',
};
---

<span class={cn('inline-flex items-center rounded-full border px-3 py-1 text-sm font-medium', toneClasses[tone], className)}>
  <slot />
</span>
