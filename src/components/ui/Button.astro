---
import { cn } from '@/lib/utils';
import Icon from '@/components/ui/Icon.astro';

interface Props {
  href?: string;
  type?: 'button' | 'submit' | 'reset';
  variant?: 'primary' | 'secondary' | 'accent' | 'light' | 'ghost-light';
  class?: string;
  iconLeft?: 'phone' | 'mail' | 'map-pin' | 'arrow-right' | 'sparkles' | 'clipboard' | 'check-circle' | 'message-square';
  iconRight?: 'phone' | 'mail' | 'map-pin' | 'arrow-right' | 'sparkles' | 'clipboard' | 'check-circle' | 'message-square';
}

const {
  href,
  type = 'button',
  variant = 'primary',
  class: className,
  iconLeft,
  iconRight,
} = Astro.props;

const classes = cn(
  'inline-flex items-center justify-center gap-2 rounded-[1rem] px-5 py-3 text-sm font-semibold transition duration-200',
  variant === 'primary' && 'bg-[var(--color-primary-700)] text-white hover:bg-[var(--color-primary-600)]',
  variant === 'secondary' && 'border border-[var(--color-primary-700)] bg-white text-[var(--color-primary-700)] hover:bg-blue-50',
  variant === 'accent' && 'bg-[var(--color-accent-600)] text-white hover:bg-[var(--color-accent-500)]',
  variant === 'light' && 'bg-white text-[var(--color-primary-700)] shadow-sm hover:bg-slate-100',
  variant === 'ghost-light' && 'border border-white/80 bg-transparent text-white hover:bg-white/12',
  className,
);
---

{href ? (
  <a href={href} class={classes}>
    {iconLeft && <Icon name={iconLeft} size={16} />}
    <slot />
    {iconRight && <Icon name={iconRight} size={16} />}
  </a>
) : (
  <button type={type} class={classes}>
    {iconLeft && <Icon name={iconLeft} size={16} />}
    <slot />
    {iconRight && <Icon name={iconRight} size={16} />}
  </button>
)}
