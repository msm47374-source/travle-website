---
import Container from './Container.astro';
import { cn } from '@/lib/utils';

interface Props {
  id?: string;
  class?: string;
  tone?: 'default' | 'alt';
  eyebrow?: string;
  title?: string;
  intro?: string;
}

const { id, class: className, tone = 'default', eyebrow, title, intro } = Astro.props;
---

<section
  id={id}
  class={cn(
    'py-16 md:py-24',
    tone === 'alt' && 'bg-[var(--color-gray-50)]',
    className,
  )}
>
  <Container>
    {(eyebrow || title || intro) && (
      <div class="mb-10 md:mb-14">
        {eyebrow && <span class="eyebrow">{eyebrow}</span>}
        {title && <h2 class="max-w-3xl text-3xl font-semibold md:text-5xl">{title}</h2>}
        {intro && <p class="lead-copy mt-4">{intro}</p>}
      </div>
    )}
    <slot />
  </Container>
</section>
