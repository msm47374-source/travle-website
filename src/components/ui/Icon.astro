---
import { cn } from '@/lib/utils';

const icons = {
  'arrow-right':
    '<path d="M5 12h14" /><path d="m12 5 7 7-7 7" />',
  briefcase:
    '<rect x="3" y="7" width="18" height="13" rx="2" /><path d="M8 7V5a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" /><path d="M3 12h18" />',
  building:
    '<path d="M4 21V7a2 2 0 0 1 2-2h7v16" /><path d="M13 21V3h5a2 2 0 0 1 2 2v16" /><path d="M8 9h1" /><path d="M8 13h1" /><path d="M8 17h1" /><path d="M16 9h1" /><path d="M16 13h1" /><path d="M16 17h1" />',
  clipboard:
    '<rect x="7" y="4" width="10" height="17" rx="2" /><path d="M9 4.5h6a1.5 1.5 0 0 1 0 3H9a1.5 1.5 0 0 1 0-3Z" /><path d="M9 12h6" /><path d="M9 16h4" />',
  clock:
    '<circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 3" />',
  'check-circle':
    '<circle cx="12" cy="12" r="9" /><path d="m8.5 12 2.5 2.5 4.5-5" />',
  facebook:
    '<path fill="currentColor" stroke="none" d="M13.5 21v-7h2.3l.4-3h-2.7V9.2c0-.9.3-1.5 1.6-1.5H16V5.1c-.3 0-1.2-.1-2.3-.1-2.3 0-3.8 1.4-3.8 4V11H7.5v3h2.4v7h3.6Z" />',
  house:
    '<path d="m3 10 9-7 9 7" /><path d="M5 9.5V20h14V9.5" /><path d="M9 20v-6h6v6" />',
  instagram:
    '<rect x="3" y="3" width="18" height="18" rx="5" /><circle cx="12" cy="12" r="4" /><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />',
  linkedin:
    '<rect x="3" y="3" width="18" height="18" rx="2" /><path d="M8 10v7" /><path d="M8 7h.01" /><path d="M12 17v-4a2 2 0 1 1 4 0v4" /><path d="M12 10v7" />',
  mail:
    '<rect x="3" y="5" width="18" height="14" rx="2" /><path d="m3 7 9 6 9-6" />',
  menu:
    '<path d="M4 7h16" /><path d="M4 12h16" /><path d="M4 17h16" />',
  'message-square':
    '<path d="M21 15a2 2 0 0 1-2 2H8l-5 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />',
  'map-pin':
    '<path d="M12 21s-6-4.35-6-10a6 6 0 1 1 12 0c0 5.65-6 10-6 10Z" /><circle cx="12" cy="11" r="2.5" />',
  phone:
    '<path d="M22 16.92v3a2 2 0 0 1-2.18 2A19.8 19.8 0 0 1 3.08 5.18 2 2 0 0 1 5.07 3h3a2 2 0 0 1 2 1.72c.12.9.33 1.78.62 2.61a2 2 0 0 1-.45 2.11L9 10.82a16 16 0 0 0 4.18 4.18l1.38-1.24a2 2 0 0 1 2.11-.45c.83.29 1.71.5 2.61.62A2 2 0 0 1 22 16.92Z" />',
  quote:
    '<path d="M9 11H5a2 2 0 0 1 2-2V7a4 4 0 0 0-4 4v2a3 3 0 0 0 3 3h3z" /><path d="M19 11h-4a2 2 0 0 1 2-2V7a4 4 0 0 0-4 4v2a3 3 0 0 0 3 3h3z" />',
  shield:
    '<path d="M12 3 5 6v5c0 5 3.4 8.2 7 10 3.6-1.8 7-5 7-10V6l-7-3Z" /><path d="m9.5 12 2 2 3-4" />',
  sparkles:
    '<path d="m12 3 1.6 4.4L18 9l-4.4 1.6L12 15l-1.6-4.4L6 9l4.4-1.6L12 3Z" /><path d="m19 16 .8 2.2L22 19l-2.2.8L19 22l-.8-2.2L16 19l2.2-.8L19 16Z" /><path d="m5 14 .9 2.1L8 17l-2.1.9L5 20l-.9-2.1L2 17l2.1-.9L5 14Z" />',
  user:
    '<circle cx="12" cy="8" r="4" /><path d="M4 21a8 8 0 0 1 16 0" />',
} as const;

type IconName = keyof typeof icons;

interface Props {
  name: IconName;
  class?: string;
  size?: number;
  strokeWidth?: number;
}

const { name, class: className, size = 18, strokeWidth = 1.8 } = Astro.props;
const markup = icons[name];
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={cn('shrink-0', className)}
  aria-hidden="true"
>
  <Fragment set:html={markup} />
</svg>
