---
import { absoluteUrl } from '@/lib/seo';
import { site } from '@/data/site';

interface Props {
  name: string;
  description: string;
  path: string;
  areaServed?: string;
}

const { name, description, path, areaServed = 'Darwin' } = Astro.props;

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name,
  description,
  areaServed: {
    '@type': 'City',
    name: areaServed,
  },
  provider: {
    '@type': 'LocalBusiness',
    name: site.legalName,
    telephone: site.displayPhone,
    url: site.siteUrl,
  },
  url: absoluteUrl(path),
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)}></script>
