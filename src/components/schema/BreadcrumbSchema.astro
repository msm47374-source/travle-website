---
import { buildBreadcrumbSchema } from '@/lib/seo';

interface Item {
  name: string;
  path: string;
}

interface Props {
  items: Item[];
}

const { items } = Astro.props;
const schema = buildBreadcrumbSchema(items);
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)}></script>
